# Copy this file to .env.local and set the secrets (never commit .env.local).
# Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID → Client secret

GOOGLE_OAUTH_CLIENT_SECRET=paste_client_secret_here

###> Paymongo (mobile “Pay with Paymongo”) ###
# Dashboard → https://dashboard.paymongo.com → Developers → Secret API keys (sk_test_... for testing)
PAYMONGO_SECRET_KEY=sk_test_paste_your_secret_key_here
###< Paymongo ###

# Paymongo Dashboard → Developers → API keys → Secret key (sk_test_... or sk_live_...)
PAYMONGO_SECRET_KEY=
