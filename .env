# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
# Required for CSRF (registration, login, forms). Empty or changing secret invalidates tokens between requests.
APP_SECRET=0cbbc3ac5a708c1f81d60d8e648f7f30
###< symfony/framework-bundle ###
GOOGLE_OAUTH_CLIENT_ID=264534690497-r526rlqoptnnbkmk19bnro0sdnkji1hv.apps.googleusercontent.com
# React Native webClientId (src/config/google.ts) — add if different from GOOGLE_OAUTH_CLIENT_ID above
GOOGLE_MOBILE_WEB_CLIENT_ID=264534690497-j0cl3eep1p4ensqk7es8moj6npsl92o7.apps.googleusercontent.com
# Must match the Client secret for the OAuth client above (Google Cloud → Credentials). Prefer .env.local.
GOOGLE_OAUTH_CLIENT_SECRET=
# Paymongo secret key (sk_test_... or sk_live_...) — put real key in .env.local to use live Paymongo API
PAYMONGO_SECRET_KEY=
# When true and PAYMONGO_SECRET_KEY is empty, dev uses a local demo checkout (no Paymongo account needed)
PAYMONGO_DEV_MOCK=1
###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
DATABASE_URL="mysql://webdev_apartment_user:webdev_apartment_password@127.0.0.1:3308/webdev_apartment_db?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
#DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
# Base URL for OAuth redirects and verification links in emails. For phone testing on the same Wi‑Fi,
# override in .env.local with your PC's LAN IP (ipconfig / ifconfig), e.g. http://192.168.1.50:8000 — not 127.0.0.1.
DEFAULT_URI=http://127.0.0.1:8000

###> symfony/mailer ###
# From address for registration/verification (must match a verified sender if you use Brevo).
MAILER_DEFAULT_EMAIL="CasaClick <daqmich3@gmail.com>"
# Registration sends a verification email. With the default below, NO email leaves your machine —
# messages are discarded. To receive verification mail, create .env.local (gitignored) and set:
#   MAILER_DSN="smtp://YOUR_EMAIL@gmail.com:YOUR_APP_PASSWORD@smtp.gmail.com:587"
# Gmail: enable 2-Step Verification, then create an App password (Account → Security).
# URL-encode special characters in the password (e.g. %40 for @).
#
# Brevo: install symfony/brevo-mailer, then in .env.local use the exact "SMTP login" + SMTP key from
# Brevo → SMTP & API (535 = wrong login or key; regenerate the key if needed). Example:
#   MAILER_DSN="brevo+smtp://YOUR_SMTP_LOGIN:YOUR_SMTP_KEY@default"
# Or use the REST API key (xkeysib-…): MAILER_DSN="brevo+api://YOUR_API_KEY@default"
# mailer:test defaults to from@example.org — Brevo rejects that. Use the same identity as MAILER_DEFAULT_EMAIL:
#   php bin/console mailer:test you@example.com --from="CasaClick <same-as-mailer-default-email>"
# Deploy: copy .env.local from dev or set MAILER_DSN on the server — null transport sends nothing and the app will show an error after registration.
MAILER_DSN=null://null
###< symfony/mailer ###

###> Google OAuth (for Staff login) ###
# Console: https://console.cloud.google.com/apis/credentials — OAuth client type: Web application
# Put GOOGLE_OAUTH_CLIENT_SECRET in .env.local (gitignored). If Google says invalid_client, open the
# same OAuth client in Console, copy Client secret or click Reset secret and paste the new value.
#
# If Google shows 403 / “no access” on accounts.google.com (not your app): fix OAuth consent screen — NOT Symfony.
#   • APIs & Services → OAuth consent screen → User type must be External to sign in with @gmail.com
#     (Internal = Google Workspace accounts in YOUR org only).
#   • While Publishing status is “Testing”, add every Gmail you use under Test users → Add users.
#   • Credentials → your Web client → Authorized JavaScript origins: http://127.0.0.1:8000 and http://localhost:8000
#   • Same place → Authorized redirect URIs (exact host/port you use in the browser):
#       http://127.0.0.1:8000/connect/google/check
#       http://localhost:8000/connect/google/check
#   • Optional: APIs & Services → Library → enable “Google People API” (helps some projects).
#
# Authorized redirect URIs (must match exactly, including host and port):
#   http://127.0.0.1:8000/connect/google/check
# Add http://localhost:8000/connect/google/check too if you open the site via localhost.
###< Google OAuth (for Staff login) ###

