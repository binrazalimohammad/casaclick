{% extends 'base.html.twig' %}

{% block title %}Active Listings{% endblock %}

{% block body %}
<div class="listings-container">
    <div class="page-title">
        <i class="fa fa-building"></i> Active Listings
    </div>
    
    <div class="header-actions">
        <a href="{{ path('app_dashboard') }}" class="btn btn-outline-dark">
            <i class="fa fa-arrow-left"></i> Dashboard
        </a>
        <a href="{{ path('app_product_new') }}" class="btn btn-dark">
            <i class="fa fa-plus"></i> New Listing
        </a>
    </div>

    <!-- Property Listings Tiles -->
    <div class="row g-4 mb-5">
        <div class="col-12">
            <div class="card p-4" style="border-radius: 16px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0"><i class="fa fa-list-alt"></i> Property Listings</h3>
                    <span class="badge bg-primary">{{ products|length }} Active</span>
                </div>
                <div class="property-tiles">
                    {% for product in products %}
                        <div class="property-tile">
                            <div class="tile-image">
                                {% if product.image %}
                                    <img src="{{ asset('uploads/images/' ~ product.image) }}" alt="{{ product.name }}">
                                {% else %}
                                    <div class="tile-placeholder"><i class="fa fa-home"></i></div>
                                {% endif %}
                            </div>
                            <div class="tile-content">
                                <h4 class="tile-title">{{ product.name }}</h4>
                                <p class="tile-price">₱{{ product.price|number_format(0, '.', ',') }}</p>
                                <div class="tile-actions">
                                    <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-sm btn-outline-primary">
                                        <i class="fa fa-eye"></i> View
                                    </a>
                                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-primary">
                                        <i class="fa fa-edit"></i> Edit
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-5">
                            <i class="fa fa-home" style="font-size: 48px; color: #ddd;"></i>
                            <p class="mt-2">No property listings found</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

</div>

{% endblock %}
