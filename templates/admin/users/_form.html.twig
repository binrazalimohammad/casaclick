{{ form_start(form, {'attr': {'class': 'user-form'}}) }}
    <div class="form-section">
        <h3 class="section-title">
            <i class="fa fa-user"></i> Basic Information
        </h3>
        
        <div class="form-group">
            <label class="field-label">
                <i class="fa fa-user"></i> Full Name
            </label>
            <div class="input-wrapper">
                {{ form_widget(form.name, {'attr': {'class': 'form-input', 'placeholder': 'Enter full name'}}) }}
            </div>
            {{ form_errors(form.name) }}
        </div>

        <div class="form-group">
            <label class="field-label">
                <i class="fa fa-envelope"></i> Email Address
            </label>
            <div class="input-wrapper">
                {{ form_widget(form.email, {'attr': {'class': 'form-input', 'placeholder': 'Enter email address'}}) }}
            </div>
            {{ form_errors(form.email) }}
        </div>
    </div>

    <div class="form-section">
        <h3 class="section-title">
            <i class="fa fa-shield"></i> Roles & Permissions
        </h3>
        
        <div class="form-group">
            <label class="field-label">
                <i class="fa fa-users"></i> User Roles
            </label>
            <div class="input-wrapper">
                {{ form_widget(form.roles, {'attr': {'class': 'form-input form-select'}}) }}
            </div>
            {{ form_errors(form.roles) }}
            <small class="form-help">Select one or more roles for this user</small>
        </div>
    </div>

    <div class="form-section">
        <h3 class="section-title">
            <i class="fa fa-lock"></i> Security
        </h3>
        
        <div class="form-group">
            <label class="field-label">
                <i class="fa fa-key"></i> Password
            </label>
            <div class="input-wrapper">
                {{ form_widget(form.plainPassword, {'attr': {'class': 'form-input', 'placeholder': 'Enter new password'}}) }}
            </div>
            {{ form_errors(form.plainPassword) }}
            <small class="form-help">Leave blank to keep current password</small>
        </div>

        <div class="form-group">
            <label class="field-label">
                <i class="fa fa-toggle-on"></i> Account Status
            </label>
            <div class="checkbox-wrapper">
                {{ form_widget(form.isEnabled, {'attr': {'class': 'form-checkbox'}}) }}
                <label for="{{ form.isEnabled.vars.id }}" class="checkbox-label">
                    <span class="checkbox-custom"></span>
                    <span class="checkbox-text">Enable this user account</span>
                </label>
            </div>
            {{ form_errors(form.isEnabled) }}
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-submit">
            <i class="fa fa-save"></i> {{ button_label|default('Save') }}
        </button>
        <a class="btn-cancel" href="{{ path('app_admin_user_index') }}">
            <i class="fa fa-times"></i> Cancel
        </a>
    </div>
{{ form_end(form) }}

<style>
    .user-form {
        width: 100%;
    }

    .form-section {
        margin-bottom: 40px;
        padding-bottom: 30px;
        border-bottom: 1px solid #E8DCC0;
    }

    .form-section:last-of-type {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .section-title {
        color: #5C4033;
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 24px 0;
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: 'Nunito', 'Poppins', 'Quicksand', sans-serif;
    }

    .section-title i {
        color: #8B4513;
        font-size: 22px;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .field-label {
        color: #5C4033;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Nunito', 'Poppins', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .field-label i {
        color: #8B7355;
        font-size: 14px;
    }

    .input-wrapper {
        position: relative;
    }

    .form-input {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid #E8DCC0;
        border-radius: 12px;
        font-size: 15px;
        font-family: 'Nunito', 'Poppins', sans-serif;
        background: #FFFDF7;
        color: #5C4033;
        transition: all 0.3s ease;
    }

    .form-input:focus {
        outline: none;
        border-color: #8B4513;
        background: #FFFFFF;
        box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
    }

    .form-select {
        cursor: pointer;
    }

    .form-help {
        display: block;
        margin-top: 6px;
        color: #8B7355;
        font-size: 12px;
        font-style: italic;
    }

    .checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-checkbox {
        display: none;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        margin: 0;
    }

    .checkbox-custom {
        width: 24px;
        height: 24px;
        border: 2px solid #E8DCC0;
        border-radius: 6px;
        background: #FFFDF7;
        position: relative;
        transition: all 0.3s ease;
    }

    .form-checkbox:checked + .checkbox-label .checkbox-custom {
        background: #8B4513;
        border-color: #8B4513;
    }

    .form-checkbox:checked + .checkbox-label .checkbox-custom::after {
        content: '✓';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-size: 14px;
        font-weight: bold;
    }

    .checkbox-text {
        color: #5C4033;
        font-size: 14px;
        font-weight: 500;
    }

    .form-actions {
        display: flex;
        gap: 16px;
        justify-content: flex-end;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid #E8DCC0;
    }

    .btn-submit {
        background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
        color: white;
        padding: 14px 32px;
        border: none;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'Nunito', 'Poppins', sans-serif;
        box-shadow: 0 4px 15px rgba(139, 69, 19, 0.3);
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
        background: linear-gradient(135deg, #A0522D 0%, #8B4513 100%);
    }

    .btn-cancel {
        background: #F8F9FA;
        color: #5C4033;
        padding: 14px 32px;
        border: 2px solid #E8DCC0;
        border-radius: 12px;
        text-decoration: none;
        font-size: 15px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .btn-cancel:hover {
        background: #E8DCC0;
        color: #3E2723;
        text-decoration: none;
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .form-actions {
            flex-direction: column;
        }

        .btn-submit,
        .btn-cancel {
            width: 100%;
            justify-content: center;
        }
    }
</style>


