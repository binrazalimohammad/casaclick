<form method="post" action="{{ path('app_admin_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to delete this user?');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
    <button class="btn-action btn-delete" type="submit" style="border: 1px solid #F5C6CB;">
        <i class="fa fa-trash"></i> Delete
    </button>
</form>


