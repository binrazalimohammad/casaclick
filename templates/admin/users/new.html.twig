{% extends 'base.html.twig' %}

{% block title %}Create User{% endblock %}

{% block body %}
<div class="page-container">
    <div class="page-header">
        <div class="breadcrumb">
            <a href="{{ path('app_admin_user_index') }}" class="breadcrumb-link">
                <i class="fa fa-users"></i> Users
            </a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Create New</span>
        </div>
    </div>

    <div class="form-wrapper">
        <div class="form-header">
            <i class="fa fa-user-plus form-icon"></i>
            <h1 class="form-title">Create New User</h1>
        </div>

        <div class="form-card">
            {% include 'admin/users/_form.html.twig' with { form: form, button_label: 'Create User' } %}
        </div>
    </div>

    <div class="back-button-container">
        <a href="{{ path('app_admin_user_index') }}" class="back-button">
            <i class="fa fa-arrow-left"></i> 
            <span>Back to Users List</span>
        </a>
    </div>
</div>

<style>
    .page-container {
        background: linear-gradient(135deg, #F8F5EE 0%, #F0E6D2 100%);
        min-height: 100vh;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }

    .page-header {
        width: 100%;
        max-width: 900px;
        margin-bottom: 20px;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: #8B7355;
    }

    .breadcrumb-link {
        color: #8B4513;
        text-decoration: none;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
        padding: 6px 12px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(10px);
    }

    .breadcrumb-link:hover {
        color: #5C4033;
        background: rgba(255, 255, 255, 0.8);
        text-decoration: none;
    }

    .breadcrumb-separator {
        color: #D2B48C;
    }

    .breadcrumb-current {
        color: #5C4033;
        font-weight: 600;
        padding: 6px 12px;
        background: rgba(139, 69, 19, 0.1);
        border-radius: 8px;
    }

    .form-wrapper {
        width: 100%;
        max-width: 900px;
        margin-bottom: 30px;
    }

    .form-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .form-icon {
        font-size: 48px;
        color: #8B4513;
        margin-bottom: 15px;
        display: block;
    }

    .form-title {
        color: #5C4033;
        font-size: 32px;
        font-weight: 800;
        margin: 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', sans-serif;
        letter-spacing: -0.5px;
    }

    .form-card {
        background: #FFFDF7;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(210, 180, 140, 0.2);
    }

    .back-button-container {
        text-align: center;
    }

    .back-button {
        background: linear-gradient(135deg, #8B4513, #A0522D);
        color: white;
        padding: 16px 32px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
        font-family: 'Nunito', 'Poppins', sans-serif;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 8px 24px rgba(139, 69, 19, 0.3);
    }

    .back-button:hover {
        background: linear-gradient(135deg, #A0522D, #8B4513);
        color: white;
        text-decoration: none;
        transform: translateY(-3px);
        box-shadow: 0 12px 32px rgba(139, 69, 19, 0.4);
    }

    @media (max-width: 768px) {
        .page-container {
            padding: 20px 15px;
        }

        .form-card {
            padding: 30px 20px;
        }

        .form-title {
            font-size: 28px;
        }
    }
</style>
{% endblock %}


