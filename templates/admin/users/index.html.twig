{% extends 'base.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}
<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">
            <i class="fa fa-users"></i> Users
        </h1>
        <a class="btn-create" href="{{ path('app_admin_user_new') }}">
            <i class="fa fa-plus"></i> Create user
        </a>
    </div>

    <div class="content-card">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="table-wrapper">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Created</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td><strong>{{ user.name }}</strong></td>
                        <td>{{ user.email }}</td>
                        <td>
                            <span class="role-badge">{{ user.primaryRole }}</span>
                        </td>
                        <td>{{ user.createdAt|date('Y-m-d H:i') }}</td>
                        <td>
                            {% if user.isEnabled %}
                                <span class="status-badge active">Active</span>
                            {% else %}
                                <span class="status-badge inactive">Disabled</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="action-buttons">
                                <a class="btn-action btn-view" href="{{ path('app_admin_user_show', {'id': user.id}) }}">
                                    <i class="fa fa-eye"></i> View
                                </a>
                                <a class="btn-action btn-edit" href="{{ path('app_admin_user_edit', {'id': user.id}) }}">
                                    <i class="fa fa-edit"></i> Edit
                                </a>
                                {% include 'admin/users/_delete_form.html.twig' with { user: user } %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center empty-state">
                            <i class="fa fa-users" style="font-size: 48px; color: #D2B48C; margin-bottom: 16px; display: block;"></i>
                            <p style="color: #8B7355;">No users found.</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .page-container {
        background: linear-gradient(135deg, #F8F5EE 0%, #F0E6D2 100%);
        min-height: 100vh;
        padding: 40px 20px;
    }

    .page-header {
        max-width: 1400px;
        margin: 0 auto 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        color: #5C4033;
        font-size: 36px;
        font-weight: 800;
        margin: 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-title i {
        color: #8B4513;
        font-size: 32px;
    }

    .btn-create {
        background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
        color: white;
        padding: 14px 28px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(139, 69, 19, 0.3);
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
        background: linear-gradient(135deg, #A0522D 0%, #8B4513 100%);
        color: white;
        text-decoration: none;
    }

    .content-card {
        background: #FFFDF7;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(210, 180, 140, 0.2);
        max-width: 1400px;
        margin: 0 auto;
    }

    .table-wrapper {
        overflow-x: auto;
    }

    .users-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 12px;
        overflow: hidden;
    }

    .users-table thead {
        background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
        color: white;
    }

    .users-table thead th {
        padding: 18px 20px;
        text-align: left;
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .users-table thead th.text-end {
        text-align: right;
    }

    .users-table tbody tr {
        border-bottom: 1px solid #E8DCC0;
        transition: background 0.2s ease;
    }

    .users-table tbody tr:hover {
        background: #FEFCF8;
    }

    .users-table tbody tr:last-child {
        border-bottom: none;
    }

    .users-table tbody td {
        padding: 18px 20px;
        color: #5C4033;
        font-size: 14px;
    }

    .users-table tbody td strong {
        color: #3E2723;
        font-weight: 600;
    }

    .role-badge {
        display: inline-block;
        background: #E8DCC0;
        color: #5C4033;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        margin-right: 6px;
        margin-bottom: 4px;
    }

    .status-badge {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge.active {
        background: #D4EDDA;
        color: #155724;
    }

    .status-badge.inactive {
        background: #F8D7DA;
        color: #721C24;
    }

    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-end;
    }

    .btn-action {
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
        font-family: 'Nunito', 'Poppins', sans-serif;
        min-width: 100px;
        width: 100%;
        justify-content: center;
        border: 1px solid transparent;
        box-sizing: border-box;
    }

    .btn-view {
        background: #F8F9FA;
        color: #5C4033;
        border: 1px solid #E8DCC0;
    }

    .btn-view:hover {
        background: #E8DCC0;
        color: #3E2723;
        transform: translateY(-1px);
        text-decoration: none;
        border-color: #D2B48C;
    }

    .btn-edit {
        background: #FFF3CD;
        color: #856404;
        border: 1px solid #FFE69C;
    }

    .btn-edit:hover {
        background: #FFE69C;
        color: #5C4033;
        transform: translateY(-1px);
        text-decoration: none;
        border-color: #FFD700;
    }

    .btn-delete {
        background: #F8D7DA;
        color: #721C24;
        border: 1px solid #F5C6CB;
        cursor: pointer;
    }

    .btn-delete:hover {
        background: #F5C6CB;
        color: #721C24;
        transform: translateY(-1px);
        text-decoration: none;
        border-color: #F1AEB5;
    }

    .empty-state {
        padding: 60px 20px !important;
    }

    @media (max-width: 768px) {
        .page-container {
            padding: 20px 15px;
        }

        .content-card {
            padding: 24px 16px;
        }

        .page-title {
            font-size: 28px;
        }

        .users-table {
            font-size: 12px;
        }

        .users-table thead th,
        .users-table tbody td {
            padding: 12px 10px;
        }

        .action-buttons {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-action {
            width: 100%;
            justify-content: center;
            min-width: auto;
        }
    }
</style>
{% endblock %}


