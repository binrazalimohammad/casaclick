{% extends 'base.html.twig' %}

{# Incremental feed poll below — disable full-page live reload #}
{% block live_sync_attributes %}{% endblock %}

{% block title %}Activity Logs{% endblock %}

{% block body %}
<div class="page-container">
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa fa-history"></i> Activity Logs
            </h1>
            <p class="page-subtitle">
                <i class="fa fa-lock"></i> Read-Only — updates every 8s
                <span id="live-feed-status" class="live-feed-badge"><i class="fa fa-circle"></i> Live</span>
            </p>
        </div>
        <a href="{{ path('app_dashboard') }}" class="btn-back">
            <i class="fa fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="content-card">
        <div class="filter-section">
            <h3 class="filter-title">
                <i class="fa fa-filter"></i> Filter Logs
            </h3>
            <form method="get" class="filter-form">
                <div class="filter-row">
                    <div class="filter-group">
                        <label class="filter-label">
                            <i class="fa fa-user"></i> User
                        </label>
                        <select name="user" class="filter-input">
                            <option value="">All Users</option>
                            {% for u in users %}
                                <option value="{{ u.id }}" {% if filters.user == u.id %}selected{% endif %}>{{ u.email }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">
                            <i class="fa fa-bolt"></i> Action
                        </label>
                        <select name="action" class="filter-input">
                            <option value="">All Actions</option>
                            {% if actions|length > 0 %}
                                {% for a in actions %}
                                    <option value="{{ a }}" {% if filters.action == a %}selected{% endif %}>{{ a }}</option>
                                {% endfor %}
                            {% else %}
                                <option value="" disabled>No actions found</option>
                            {% endif %}
                        </select>
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">
                            <i class="fa fa-calendar"></i> From Date
                        </label>
                        <input type="date" name="from" class="filter-input" value="{{ filters.from }}">
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">
                            <i class="fa fa-calendar"></i> To Date
                        </label>
                        <input type="date" name="to" class="filter-input" value="{{ filters.to }}">
                    </div>

                    <div class="filter-actions">
                        <button type="submit" class="btn-filter">
                            <i class="fa fa-search"></i> Filter
                        </button>
                        <button type="button" class="btn-reset" onclick="resetFilters()">
                            <i class="fa fa-refresh"></i> Reset
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="read-only-banner">
            <div class="banner-icon">
                <i class="fa fa-info-circle"></i>
            </div>
            <div class="banner-content">
                <strong>Read-Only Access:</strong> Activity logs are for viewing only. They cannot be modified, edited, or deleted to maintain audit integrity.
            </div>
        </div>

        <div class="table-section">
            <div class="table-wrapper">
                <table class="logs-table">
                    <thead>
                        <tr>
                            <th><i class="fa fa-id"></i> User ID</th>
                            <th><i class="fa fa-user"></i> Username</th>
                            <th><i class="fa fa-shield"></i> Role</th>
                            <th><i class="fa fa-bolt"></i> Action</th>
                            <th><i class="fa fa-bullseye"></i> Target Data</th>
                            <th><i class="fa fa-clock-o"></i> Date & Time</th>
                        </tr>
                    </thead>
                    <tbody id="logs-tbody">
                    {% for log in logs %}
                        <tr class="log-row" data-log-id="{{ log.id }}">
                            <td>
                                <span class="user-id">{{ log.user ? log.user.id : (log.targetId ? log.targetId : '-') }}</span>
                            </td>
                            <td>
                                <span class="user-email">{{ log.username ?? (log.user ? (log.user.email ?? log.user.name ?? 'Unknown') : 'System') }}</span>
                            </td>
                            <td>
                                <span class="role-badge-log">{{ log.role ?? 'ROLE_TENANT' }}</span>
                            </td>
                            <td>
                                <span class="action-badge action-{{ log.action|lower }}">
                                    <i class="fa fa-{{ log.action == 'LOGIN' ? 'sign-in' : (log.action == 'LOGOUT' ? 'sign-out' : (log.action == 'CREATE' ? 'plus' : (log.action == 'UPDATE' ? 'pencil' : 'trash'))) }}"></i>
                                    {{ log.action }}
                                </span>
                            </td>
                            <td class="target-cell">
                                {% if log.targetData %}
                                    <span class="target-data">{{ log.targetData }}</span>
                                {% else %}
                                    <span class="target-data">
                                        {% if log.targetEntity %}{{ log.targetEntity|replace({'App\\Entity\\': ''}) }}{% endif %}
                                        {% if log.targetId %} (ID: {{ log.targetId }}){% endif %}
                                    </span>
                                {% endif %}
                            </td>
                            <td class="timestamp-cell">
                                <span class="datetime">{{ log.createdAt|date('Y-m-d g:i:s A') }}</span>
                            </td>
                        </tr>
                        <tr class="log-details-row" data-log-id="{{ log.id }}" style="display: none;">
                            <td colspan="6" class="details-cell">
                                <div class="log-details-table">
                                    <table class="details-table">
                                        <tr>
                                            <td class="detail-label">Action</td>
                                            <td class="detail-value">{{ log.action }}</td>
                                        </tr>
                                        <tr>
                                            <td class="detail-label">Target Data</td>
                                            <td class="detail-value">
                                                {% if log.targetData %}
                                                    {{ log.targetData }}
                                                {% else %}
                                                    {% if log.targetEntity %}{{ log.targetEntity }}{% endif %}
                                                    {% if log.targetId %} (ID: {{ log.targetId }}){% endif %}
                                                {% endif %}
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="empty-state">
                                <div class="empty-content">
                                    <i class="fa fa-inbox" style="font-size: 48px; color: #D2B48C; margin-bottom: 16px; display: block;"></i>
                                    <p style="color: #8B7355; font-size: 16px;">No logs found for the selected filters.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

