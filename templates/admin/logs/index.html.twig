<script>
    // Reset filters function
    function resetFilters() {
        // Clear all form fields
        const form = document.querySelector('.filter-form');
        if (form) {
            form.querySelector('select[name="user"]').value = '';
            form.querySelector('select[name="action"]').value = '';
            form.querySelector('input[name="from"]').value = '';
            form.querySelector('input[name="to"]').value = '';
            
            // Redirect to the logs page without query parameters
            window.location.href = '{{ path('app_admin_logs') }}';
        }
    }

    let lastSeenAt = {{ newestAt|json_encode|raw }};
    const feedUrl = {{ path('app_admin_logs_feed')|json_encode|raw }};
    const seenIds = new Set();

    document.querySelectorAll('.log-row').forEach(function(row) {
        const id = row.getAttribute('data-log-id');
        if (id) seenIds.add(id);
    });

    function actionIcon(action) {
        if (action === 'LOGIN' || action.indexOf('LOGIN') >= 0) return 'sign-in';
        if (action === 'LOGOUT' || action.indexOf('LOGOUT') >= 0) return 'sign-out';
        if (action === 'CREATE' || action.indexOf('CREATE') >= 0) return 'plus';
        if (action === 'UPDATE') return 'pencil';
        if (action.indexOf('MOBILE') >= 0) return 'mobile';
        return 'bolt';
    }

    function prependLogRow(log) {
        if (seenIds.has(String(log.id))) return;
        seenIds.add(String(log.id));
        const tbody = document.getElementById('logs-tbody');
        if (!tbody) return;
        const tr = document.createElement('tr');
        tr.className = 'log-row log-row-new';
        tr.setAttribute('data-log-id', log.id);
        tr.innerHTML =
            '<td><span class="user-id">' + (log.userId || '-') + '</span></td>' +
            '<td><span class="user-email">' + (log.username || 'System') + '</span></td>' +
            '<td><span class="role-badge-log">' + (log.role || 'ROLE_TENANT') + '</span></td>' +
            '<td><span class="action-badge action-' + log.action.toLowerCase() + '"><i class="fa fa-' + actionIcon(log.action) + '"></i> ' + log.action + '</span></td>' +
            '<td class="target-cell"><span class="target-data">' + (log.targetData || '') + '</span></td>' +
            '<td class="timestamp-cell"><span class="datetime">' + log.createdAt + '</span></td>';
        tbody.insertBefore(tr, tbody.firstChild);
        setTimeout(function() { tr.classList.remove('log-row-new'); }, 3000);
        if (log.createdAtIso && log.createdAtIso > lastSeenAt) {
            lastSeenAt = log.createdAtIso;
        }
    }

    function pollActivityFeed() {
        const status = document.getElementById('live-feed-status');
        fetch(feedUrl + '?since=' + encodeURIComponent(lastSeenAt), { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(json) {
                if (!json.success || !json.data) return;
                json.data.forEach(prependLogRow);
                if (json.serverTime) lastSeenAt = json.serverTime;
                if (status) status.classList.remove('live-feed-error');
            })
            .catch(function() {
                if (status) status.classList.add('live-feed-error');
            });
    }

    setInterval(pollActivityFeed, 8000);

    document.addEventListener('DOMContentLoaded', function() {
        const logRows = document.querySelectorAll('.log-row');
        
        logRows.forEach(row => {
            row.addEventListener('click', function() {
                const logId = this.getAttribute('data-log-id');
                const detailsRow = document.querySelector(`.log-details-row[data-log-id="${logId}"]`);
                
                if (detailsRow) {
                    if (detailsRow.style.display === 'none') {
                        detailsRow.style.display = 'table-row';
                        this.style.background = '#FFF8E1';
                    } else {
                        detailsRow.style.display = 'none';
                        this.style.background = '';
                    }
                }
            });
        });
    });
</script>
