{% extends 'base.html.twig' %}
{% block title %}View Bookings{% endblock %}
{% block body %}
<div class="page-container" id="admin-bookings-root"
     data-bookings-data-url="{{ path('app_admin_bookings_data') }}"
     data-bookings-feed-url="{{ path('app_admin_bookings_feed') }}">
    <h1><i class="fa fa-calendar"></i> View Bookings</h1>
    <p class="text-muted">
        <strong>Read-only.</strong> Only the <strong>landlord</strong> can approve or reject applications
        (website → <strong>Applications</strong>). Tenants are notified on their mobile app when the landlord decides.
        <span id="bookings-live-badge" class="badge bg-success"><i class="fa fa-circle"></i> Live</span>
    </p>

    <div class="table-responsive" style="margin-top: 24px;">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tenant</th>
                    <th>Listing</th>
                    <th>Landlord</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody id="admin-bookings-tbody">
            {% for booking in bookings %}
                <tr data-booking-id="{{ booking.id }}">
                    <td>{{ booking.id }}</td>
                    <td>{{ booking.tenant.email ?? booking.tenant.name }}</td>
                    <td>{{ booking.listing.name ?? '—' }}</td>
                    <td>{{ booking.landlord.email ?? booking.landlord.name ?? '—' }}</td>
                    <td><span class="badge">{{ statuses[booking.status] ?? booking.status }}</span></td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-center text-muted">No bookings found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <p><a href="{{ path('app_admin') }}">← Back to Admin Area</a></p>
</div>
{% endblock %}
