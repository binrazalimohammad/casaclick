{% extends 'base.html.twig' %}

{% block title %}Category Details{% endblock %}

{% block body %}
    <div class="container mt-5" style="max-width: 700px;">
        <h1 class="text-center mb-4">📂 Category Details</h1>

        <div class="card shadow-sm p-4" style="border-radius: 12px; background:#fffaf0;">
            <table class="table table-striped mb-0">
                <tbody>
                    <tr>
                        <th style="width: 30%;">ID</th>
                        <td>{{ category.id }}</td>
                    </tr>
                    <tr>
                        <th>Name</th>
                        <td>{{ category.name }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">
            <a href="{{ path('app_category_index') }}" 
               class="btn"
               style="
                   background:#8B4513;
                   color:#fff;
                   border:none;
                   border-radius:8px;
                   font-weight:bold;
                   padding:10px 20px;
                   text-decoration:none;
                   transition:all 0.2s ease;
               "
               onmouseover="this.style.background='#A0522D';" 
               onmouseout="this.style.background='#8B4513';">
                ⬅ Back to List
            </a>

            <a href="{{ path('app_category_edit', {'id': category.id}) }}" 
               class="btn"
               style="
                   background:#DEB887;
                   color:#3E2723;
                   border:none;
                   border-radius:8px;
                   font-weight:bold;
                   padding:10px 20px;
                   text-decoration:none;
                   transition:all 0.2s ease;
               "
               onmouseover="this.style.background='#A9825C'; this.style.color='#fff';" 
               onmouseout="this.style.background='#DEB887'; this.style.color='#3E2723';">
                ✏ Edit
            </a>

            {{ include('category/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
