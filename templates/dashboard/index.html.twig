{% extends 'base.html.twig' %}

{% block title %}Dashboard — CasaClick{% endblock %}

{% block javascripts_head %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
{% endblock %}

{% block body %}
<div class="dashboard-container cc-dashboard">
    <header class="cc-dash-hero">
        <div>
            <p class="cc-dash-eyebrow">Staff overview</p>
            <h1 class="cc-dash-title">Dashboard</h1>
            <p class="cc-dash-sub">
                Welcome back{% if user.name %}, {{ user.name }}{% endif %}. Here’s a snapshot of listings, activity, and notifications.
            </p>
        </div>
    </header>

    <div class="cc-dash-toolbar">
        <div class="cc-dash-search">
            <input type="search" id="dash-search" placeholder="Search listings…" aria-label="Search listings" autocomplete="off">
        </div>
        <div class="cc-dash-actions">
            <a href="{{ path('app_maps') }}" class="btn btn-outline-secondary">
                <i class="fa fa-map-marker"></i> Maps
            </a>
            <a href="{{ path('app_product_new') }}" class="btn btn-dark">
                <i class="fa fa-plus"></i> New listing
            </a>
        </div>
    </div>

    <section class="stats-grid" aria-label="Key statistics">
        <article class="stat-card">
            <div class="stat-header">
                <p class="stat-title">Total properties</p>
                <div class="stat-icon" aria-hidden="true"><i class="fa fa-home"></i></div>
            </div>
            <p class="stat-value">{{ stats.totalProperties|default(0) }}</p>
            <div class="stat-change">Across the marketplace</div>
        </article>
        <article class="stat-card">
            <div class="stat-header">
                <p class="stat-title">Combined listing value</p>
                <div class="stat-icon" aria-hidden="true"><i class="fa fa-money"></i></div>
            </div>
            <p class="stat-value">₱{{ stats.totalRevenue|default(0)|number_format(0, '.', ',') }}</p>
            <div class="stat-change">Sum of listed prices</div>
        </article>
        <article class="stat-card">
            <div class="stat-header">
                <p class="stat-title">Registered users</p>
                <div class="stat-icon" aria-hidden="true"><i class="fa fa-users"></i></div>
            </div>
            <p class="stat-value">{{ stats.totalUsers|default(0) }}</p>
            <div class="stat-change">All roles</div>
        </article>
        <article class="stat-card">
            <div class="stat-header">
                <p class="stat-title">Landlords</p>
                <div class="stat-icon" aria-hidden="true"><i class="fa fa-user-circle"></i></div>
            </div>
            <p class="stat-value">{{ stats.totalLandlords|default(0) }}</p>
            <div class="stat-change">Accounts with landlord role</div>
        </article>
    </section>

    <div class="row g-4">
        <div class="col-12 col-lg-5">
            <div class="cc-dash-panel">
                <div class="cc-dash-panel__head">
                    <h2 class="cc-dash-panel__title">Recent listings</h2>
                    <span class="cc-dash-panel__hint">Latest</span>
                </div>
                <div class="listings-tiles">
                    {% for p in products|slice(0, 4) %}
                        <div class="listing-tile">
                            <a href="{{ path('app_dashboard') }}?id={{ p.id }}" class="tile-link">
                                <div class="tile-image">
                                    {% if p.image %}
                                        <img src="{{ asset('uploads/images/' ~ p.image) }}" alt="">
                                    {% else %}
                                        <div class="tile-placeholder" aria-hidden="true">🏠</div>
                                    {% endif %}
                                </div>
                                <div class="tile-content">
                                    <div class="tile-title">{{ p.name }}</div>
                                    <div class="tile-sub text-muted">{{ p.category ? p.category.name : 'Uncategorized' }}</div>
                                    <div class="tile-price">₱{{ p.price|number_format(0, '.', ',') }}</div>
                                    <div class="tile-frequency">per month</div>
                                    <div class="tile-meta"><span>View</span></div>
                                </div>
                            </a>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-4">No listings yet.</div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-7">
            <div class="cc-dash-detail detail-card">
                {% if featured %}
                    <div class="detail-image">
                        <img src="{{ asset('uploads/images/' ~ featured.image) }}" alt="{{ featured.name }}">
                    </div>
                    <div class="detail-header">
                        <div class="detail-info">
                            <h3 class="detail-title">{{ featured.name }}</h3>
                            <span class="detail-price">₱{{ featured.price|number_format(0, '.', ',') }}</span>
                        </div>
                        <div class="detail-actions">
                            <a href="{{ path('app_product_show', {id: featured.id}) }}" class="btn btn-outline-dark btn-sm">
                                <i class="fa fa-eye"></i> View
                            </a>
                            <a href="{{ path('app_product_edit', {id: featured.id}) }}" class="btn btn-dark btn-sm">
                                <i class="fa fa-pencil"></i> Edit
                            </a>
                        </div>
                    </div>
                    <p class="detail-desc">{% set _d = featured.description ?? '' %}{{ _d|length > 320 ? _d|slice(0, 320) ~ '…' : _d }}</p>
                {% else %}
                    <div class="text-center text-muted py-5 px-3">Select a listing on the left to preview details.</div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-12 col-xl-8">
            <div class="cc-dash-panel">
                <div class="cc-dash-panel__head">
                    <h2 class="cc-dash-panel__title">Listing board</h2>
                </div>
                <div class="property-tiles">
                    {% for p in products|slice(0, 3) %}
                        <div class="property-tile">
                            <div class="tile-image">
                                {% if p.image %}
                                    <img src="{{ asset('uploads/images/' ~ p.image) }}" alt="">
                                {% else %}
                                    <div class="tile-placeholder"><i class="fa fa-home"></i></div>
                                {% endif %}
                            </div>
                            <div class="tile-content">
                                <h4 class="tile-title">{{ p.name }}</h4>
                                <p class="tile-price">₱{{ p.price|number_format(0, '.', ',') }}</p>
                                <div class="tile-actions">
                                    <a href="{{ path('app_product_show', {'id': p.id}) }}" class="btn btn-sm btn-outline-primary">
                                        <i class="fa fa-eye"></i> View
                                    </a>
                                    <a href="{{ path('app_product_edit', {'id': p.id}) }}" class="btn btn-sm btn-primary">
                                        <i class="fa fa-edit"></i> Edit
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-5 w-100">
                            <i class="fa fa-home" style="font-size: 2.5rem; opacity: 0.25;"></i>
                            <p class="mt-2 mb-0">No property listings found</p>
                        </div>
                    {% endfor %}
                </div>
                <div class="text-center pt-3 mt-3" style="border-top: 1px solid rgba(92,64,51,0.08);">
                    <a href="{{ path('app_product_index') }}" class="view-all-btn">
                        <i class="fa fa-list"></i> View all listings
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="cc-dash-panel">
                <div class="cc-dash-panel__head">
                    <h2 class="cc-dash-panel__title">
                        Notifications
                        {% if unreadCount > 0 %}
                            <span class="badge rounded-pill text-bg-danger ms-1" style="font-size: 0.7rem;">{{ unreadCount }}</span>
                        {% endif %}
                    </h2>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="markAllAsRead()">Mark all read</button>
                </div>
                <div class="notifications-list" style="max-height: 400px; overflow-y: auto;">
                    {% for notification in notifications %}
                        <div class="notification-item {% if not notification.isRead %}notification-unread{% endif %}" data-notification-id="{{ notification.id }}">
                            <div class="notification-content">
                                <div class="notification-header">
                                    <div class="notification-type">
                                        {% if notification.type == 'listing_created' %}
                                            <i class="fa fa-home notification-icon icon-success"></i>
                                            <span class="notification-type-text text-success">New listing</span>
                                        {% elseif notification.type == 'application_submitted' %}
                                            <i class="fa fa-file-text notification-icon icon-info"></i>
                                            <span class="notification-type-text text-info">New application</span>
                                        {% elseif notification.type == 'application_approved' %}
                                            <i class="fa fa-check-circle notification-icon icon-success"></i>
                                            <span class="notification-type-text text-success">Application approved</span>
                                        {% elseif notification.type == 'application_rejected' %}
                                            <i class="fa fa-times-circle notification-icon icon-danger"></i>
                                            <span class="notification-type-text text-danger">Application declined</span>
                                        {% elseif notification.type == 'payment_submitted' %}
                                            <i class="fa fa-money notification-icon icon-warning"></i>
                                            <span class="notification-type-text text-warning">Payment submitted</span>
                                        {% elseif notification.type == 'payment_approved' %}
                                            <i class="fa fa-check-circle notification-icon icon-success"></i>
                                            <span class="notification-type-text text-success">Payment approved</span>
                                        {% elseif notification.type == 'payment_rejected' %}
                                            <i class="fa fa-times-circle notification-icon icon-danger"></i>
                                            <span class="notification-type-text text-danger">Payment rejected</span>
                                        {% elseif notification.type == 'listing_updated' %}
                                            <i class="fa fa-edit notification-icon icon-warning"></i>
                                            <span class="notification-type-text text-warning">Listing updated</span>
                                        {% elseif notification.type == 'order_update' %}
                                            <i class="fa fa-shopping-bag notification-icon icon-info"></i>
                                            <span class="notification-type-text text-info">Order update</span>
                                        {% else %}
                                            <i class="fa fa-bell notification-icon"></i>
                                            <span class="notification-type-text">Notification</span>
                                        {% endif %}
                                    </div>
                                    <button type="button" class="notification-mark-read" onclick="markAsRead({{ notification.id }})" title="Mark as read" aria-label="Mark as read">
                                        <i class="fa fa-check"></i>
                                    </button>
                                </div>
                                <div class="notification-message">{{ notification.message }}</div>
                                <div class="notification-time">{{ notification.createdAt|date('Y-m-d H:i') }}</div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-4">
                            <i class="fa fa-bell" style="font-size: 2rem; opacity: 0.2;"></i>
                            <p class="mt-2 mb-0 small">No notifications</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {% set listingNotifications = notifications|filter(n => n.type == 'listing_created' or n.type == 'listing_updated')|filter(n => not n.isRead) %}
    {% if listingNotifications|length > 0 %}
        <div id="reviewBanner" class="banner-notice mt-4">
            <div class="banner-content">
                <div class="banner-message">
                    <i class="fa fa-bell" style="margin-right: 8px;"></i>
                    {% if listingNotifications|length == 1 %}
                        A landlord has {{ listingNotifications[0].type == 'listing_created' ? 'posted a new listing' : 'updated a listing' }} — please review.
                    {% else %}
                        Landlords have new or updated listings — please review.
                    {% endif %}
                </div>
                <div class="banner-actions">
                    <a href="{{ path('app_product_index') }}" class="banner-btn primary">
                        <i class="fa fa-check"></i> Review listings
                    </a>
                    <button type="button" class="banner-btn secondary" onclick="dismissBanner()">
                        <i class="fa fa-times"></i> Dismiss
                    </button>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="row g-4 mt-2">
        <div class="col-12 col-xl-6">
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title mb-0">Growth (sample)</h3>
                    <span class="badge rounded-pill text-bg-light border">Yearly</span>
                </div>
                <div class="chart-content" style="height: auto; padding: 0.5rem 0 1rem;">
                    <canvas id="growthChart" height="200"></canvas>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title mb-0">Activity (sample)</h3>
                    <span class="badge rounded-pill text-bg-light border">6 months</span>
                </div>
                <div class="chart-content" style="height: auto; padding: 0.5rem 0 1rem;">
                    <canvas id="salesChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function markAsRead(notificationId) {
            fetch('{{ path('app_notification_mark_read', {'id': 0}) }}'.replace('0', notificationId), {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const item = document.querySelector(`[data-notification-id="${notificationId}"]`);
                    if (item) {
                        item.classList.remove('notification-unread');
                    }
                    updateNotificationCount();
                }
            });
        }

        function markAllAsRead() {
            fetch('{{ path('app_notification_mark_all_read') }}', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.querySelectorAll('[data-notification-id]').forEach(item => {
                        item.classList.remove('notification-unread');
                    });
                    updateNotificationCount();
                }
            });
        }

        function updateNotificationCount() {
            fetch('{{ path('app_notification_count') }}')
                .then(response => response.json())
                .then(data => {
                    const badge = document.querySelector('.cc-dash-panel .badge.text-bg-danger');
                    if (data.count > 0) {
                        if (badge) {
                            badge.textContent = data.count;
                        }
                    } else {
                        if (badge) {
                            badge.remove();
                        }
                    }
                });
        }

        function dismissBanner() {
            const banner = document.getElementById('reviewBanner');
            if (banner) {
                banner.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                banner.style.opacity = '0';
                banner.style.transform = 'translateY(-10px)';
                setTimeout(() => {
                    banner.remove();
                }, 300);
            }
        }

        (function() {
            const growthCtx = document.getElementById('growthChart');
            if (growthCtx && window.Chart) {
                new Chart(growthCtx, {
                    type: 'bar',
                    data: {
                        labels: ['Q1', 'Q2', 'Q3', 'Q4'],
                        datasets: [{
                            label: 'Revenue (sample)',
                            data: [120000, 185000, 160000, 220000],
                            backgroundColor: 'rgba(109, 76, 65, 0.75)',
                            borderRadius: 6,
                        }]
                    },
                    options: {
                        scales: {
                            y: { ticks: { callback: v => '₱' + Number(v).toLocaleString() } },
                            x: { grid: { display: false } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            }

            const salesCtx = document.getElementById('salesChart');
            if (salesCtx && window.Chart) {
                new Chart(salesCtx, {
                    type: 'line',
                    data: {
                        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                        datasets: [
                            { label: 'Listings', data: [5, 7, 6, 9, 11, 10], borderColor: '#6d4c41', backgroundColor: 'rgba(109,76,65,0.08)', fill: true, tension: 0.35 },
                            { label: 'Applications', data: [3, 4, 4, 6, 7, 8], borderColor: '#a67c52', tension: 0.35, fill: false }
                        ]
                    },
                    options: {
                        plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } },
                        scales: { y: { beginAtZero: true } }
                    }
                });
            }
        })();
    </script>
{% endblock %}
