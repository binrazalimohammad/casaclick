<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - CasaClick</title>
    <link href="https://maxcdn.bootstrapcdn.com/font-awesome/latest/css/font-awesome.min.css" rel="stylesheet">
    {{ encore_entry_link_tags('app') }}
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        .cc-auth-page {
            background-image: linear-gradient(160deg, rgba(255, 253, 247, 0.55), rgba(245, 230, 211, 0.35)),
                url('{{ asset('uploads/images/log in background.jpg') }}');
        }
    </style>
</head>
<body class="cc-auth-page">
    <div class="login-container" style="width:100%;max-width:min(460px,calc(100vw - 24px));padding:clamp(12px,4vw,20px);">
        <div class="cc-auth-card">
            <div class="cc-auth-card__top">
                <a href="{{ path('app_landing') }}" class="cc-back-landing"><i class="fa fa-arrow-left"></i> Back to home</a>
            </div>
            <div class="login-header" style="text-align:center;margin-bottom:1.75rem;">
                <h1 class="cc-font-display" style="font-size:clamp(1.65rem,4vw,2rem);margin-bottom:0.35rem;">Welcome back</h1>
                <p class="cc-auth-sub" style="margin-bottom:0;">Sign in to CasaClick</p>
            </div>

            {% include '_partials/cc_dismissible_flashes.html.twig' %}

            {% set v = app.request.query.get('verification') %}
            {% if v == 'success' %}
                {% include '_partials/cc_flash_item.html.twig' with {
                    variant: 'success',
                    message: 'Your email has been verified. You can now sign in.'
                } only %}
            {% elseif v == 'invalid' %}
                {% include '_partials/cc_flash_item.html.twig' with {
                    variant: 'error',
                    message: 'Invalid or expired verification link. Request a new one below if you still need to verify.'
                } only %}
            {% elseif v == 'error' %}
                {% include '_partials/cc_flash_item.html.twig' with {
                    variant: 'error',
                    message: 'Something went wrong while verifying your email. Please try again or use “Resend verification”.'
                } only %}
            {% endif %}

            {% if error %}
                {# Show Symfony’s real message (wrong password, unverified email via UserChecker, etc.) #}
                {% set login_error_message = error.messageKey|trans(error.messageData, 'security') %}
                {% include '_partials/cc_flash_item.html.twig' with {
                    variant: 'error',
                    message: login_error_message
                } only %}
            {% endif %}

            <form action="{{ path('app_login') }}" method="post">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="form-group">
                    <label for="username">Email address</label>
                    <div class="input-icon">
                        <i class="fa fa-envelope"></i>
                        <input type="text" id="username" name="_username" value="{{ last_username }}"
                               autocomplete="username" required autofocus placeholder="Enter your email">
                    </div>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-icon">
                        <i class="fa fa-lock"></i>
                        <input type="password" id="password" name="_password"
                               autocomplete="current-password" required placeholder="Enter your password">
                    </div>
                </div>

                <div class="remember-me">
                    <input type="checkbox" id="remember_me" name="_remember_me" value="on">
                    <label for="remember_me">Remember me</label>
                </div>

                <button type="submit" class="cc-btn-primary">
                    <i class="fa fa-sign-in"></i> Sign in
                </button>

                <div class="cc-auth-divider"><span>or</span></div>
                <a href="{{ path('app_google_connect') }}" class="cc-btn-google" title="Staff: Sign in with Google">
                    <i class="fa fa-google"></i> Sign in with Google (Staff)
                </a>
            </form>

            <div class="cc-auth-footer">
                <p>Don't have an account?</p>
                <a href="{{ path('app_register') }}"><i class="fa fa-user-plus"></i> Register</a>
                <p style="margin-top:10px;">
                    <a href="{{ path('app_resend_verification') }}">Didn’t get the verification email?</a>
                </p>
            </div>
        </div>
    </div>
    {{ encore_entry_script_tags('app') }}
</body>
</html>
