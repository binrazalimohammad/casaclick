<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - CasaClick</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/latest/css/font-awesome.min.css" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/latest/css/font-awesome.min.css"></noscript>
    {{ encore_entry_link_tags('auth') }}
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        .cc-auth-page {
            background-image: linear-gradient(160deg, rgba(255, 253, 247, 0.55), rgba(245, 230, 211, 0.35)),
                url('{{ asset('uploads/images/log in background.jpg') }}');
        }
        .cc-auth-card .checkbox-row {
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
            margin: 1rem 0 1.25rem;
            font-size: 0.9rem;
            color: var(--cc-muted, #6d4c41);
        }
        .cc-auth-card .checkbox-row input { margin-top: 3px; accent-color: #8b4513; }
    </style>
</head>
<body class="cc-auth-page">
    <div style="width:100%;max-width:min(520px,calc(100vw - 24px));padding:clamp(12px,4vw,20px);">
        <div class="cc-auth-card">
            <div class="cc-auth-card__top">
                <a href="{{ path('app_landing') }}" class="cc-back-landing"><i class="fa fa-arrow-left"></i> Back to home</a>
            </div>
            <div style="text-align:center;margin-bottom:1.5rem;">
                <h1 class="cc-font-display" style="font-size:clamp(1.65rem,4vw,2rem);">Create account</h1>
                <p class="cc-auth-sub">Join CasaClick to browse and apply for homes</p>
                <p class="cc-auth-sub" style="margin-top:0.65rem;font-size:0.88rem;">After you register, we’ll email you a link to verify your address. You need to verify before you can sign in.</p>
            </div>

            {% include '_partials/cc_dismissible_flashes_all_labels.html.twig' %}

            {{ form_start(registrationForm, {'attr': {'class': 'registration-form', 'novalidate': 'novalidate'}}) }}

                {% if registrationForm.vars.submitted and not registrationForm.vars.valid %}
                    <div class="cc-register-summary-error" role="alert">
                        <i class="fa fa-exclamation-circle" aria-hidden="true"></i>
                        <div>
                            <p style="margin:0 0 0.5rem;"><strong>Please fix the following.</strong> If nothing is highlighted, check your email (it may already be registered), password rules (8+ characters, letters and a number or symbol), or reload the page and try again (invalid security token).</p>
                            {{ form_errors(registrationForm) }}
                        </div>
                    </div>
                {% else %}
                    {{ form_errors(registrationForm) }}
                {% endif %}

                <div class="form-group">
                    {{ form_label(registrationForm.name) }}
                    {{ form_widget(registrationForm.name, {'attr': {'class': 'form-control', 'placeholder': 'Full name'}}) }}
                    {{ form_errors(registrationForm.name) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.email) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Email address'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.role) }}
                    {{ form_widget(registrationForm.role, {'attr': {'class': 'form-control form-select'}}) }}
                    {{ form_errors(registrationForm.role) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.first) }}
                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': 'Password'}}) }}
                    {{ form_errors(registrationForm.plainPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.second) }}
                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Repeat password'}}) }}
                    {{ form_errors(registrationForm.plainPassword.second) }}
                </div>
                {{ form_errors(registrationForm.plainPassword) }}

                <div class="checkbox-row">
                    {{ form_widget(registrationForm.agreeTerms, {'attr': {'id': 'agree_terms'}}) }}
                    <label for="agree_terms">I agree to the terms</label>
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="cc-btn-primary">
                    <i class="fa fa-user-plus"></i> Create account
                </button>
            {{ form_end(registrationForm) }}

            <div class="cc-auth-footer">
                <span>Already have an account?</span>
                <a href="{{ path('app_login') }}">Sign in</a>
                <p style="margin-top:10px;">
                    <a href="{{ path('app_resend_verification') }}">Didn’t get the verification email?</a>
                </p>
            </div>
        </div>
    </div>
    {{ encore_entry_script_tags('auth') }}
</body>
</html>
