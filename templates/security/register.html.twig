<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - CasaClick</title>
    <link href="https://maxcdn.bootstrapcdn.com/font-awesome/latest/css/font-awesome.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Nunito', 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image: url('{{ asset('uploads/images/log in background.jpg') }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            position: relative;
            background-color: #F5E6D3; /* fallback */
        }
        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0.78);
            backdrop-filter: blur(2px);
            z-index: 0;
        }
        .register-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 520px;
            padding: 20px;
        }
        .register-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 44px 38px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .register-header {
            text-align: center;
            margin-bottom: 32px;
        }
        .register-header h1 {
            font-size: 30px;
            font-weight: 800;
            color: #5C4033;
            margin-bottom: 6px;
            letter-spacing: -0.4px;
        }
        .register-header p {
            color: #8B7355;
            font-size: 14px;
            font-weight: 500;
        }
        .form-group { margin-bottom: 18px; }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #5C4033;
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 0.2px;
        }
        .form-control {
            width: 100%;
            padding: 13px 16px;
            border: 2px solid #E8DCC0;
            border-radius: 12px;
            font-size: 15px;
            font-family: 'Nunito', sans-serif;
            background: #FFFDF7;
            color: #3E2723;
            transition: all 0.3s ease;
        }
        .form-control:focus {
            outline: none;
            border-color: #C9A46D;
            background: #FFFFFF;
            box-shadow: 0 0 0 3px rgba(201, 164, 109, 0.12);
        }
        .form-control::placeholder { color: #A0825C; }
        .form-select {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%235C4033' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 12px center;
            background-size: 16px 12px;
            padding-right: 40px;
            appearance: none;
            cursor: pointer;
        }
        .error-block {
            background: #FEE;
            border: 1px solid #FCC;
            color: #C33;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 16px;
            font-size: 14px;
        }
        .checkbox-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 10px 0 4px;
        }
        .checkbox-row input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #C9A46D;
            cursor: pointer;
            margin: 0;
            flex-shrink: 0;
        }
        .checkbox-row label {
            color: #5C4033;
            font-size: 14px;
            font-weight: 500;
            margin: 0;
            cursor: pointer;
            user-select: none;
        }
        .btn-register {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Nunito', sans-serif;
            box-shadow: 0 4px 15px rgba(139, 69, 19, 0.3);
            margin-top: 8px;
        }
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
            background: linear-gradient(135deg, #A0522D 0%, #8B4513 100%);
        }
        .login-link {
            text-align: center;
            margin-top: 22px;
            padding-top: 20px;
            border-top: 1px solid #E8DCC0;
            color: #8B7355;
            font-size: 14px;
        }
        .login-link a {
            color: #8B4513;
            text-decoration: none;
            font-weight: 700;
            margin-left: 6px;
        }
        .login-link a:hover { color: #A0522D; text-decoration: underline; }
        @media (max-width: 480px) {
            .register-card { padding: 36px 26px; margin: 16px; }
            .register-header h1 { font-size: 26px; }
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="register-header">
                <h1>Create Account</h1>
                <p>Set your credentials to get started</p>
            </div>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="error-block">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {{ form_start(registrationForm, {'attr': {'class': 'registration-form'}}) }}

                <div class="form-group">
                    {{ form_label(registrationForm.name) }}
                    {{ form_widget(registrationForm.name, {'attr': {'class': 'form-control', 'placeholder': 'Enter your full name'}}) }}
                    {{ form_errors(registrationForm.name) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.email) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter your email address'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.role) }}
                    {{ form_widget(registrationForm.role, {'attr': {'class': 'form-control form-select'}}) }}
                    {{ form_errors(registrationForm.role) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.first) }}
                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control', 'type': 'password', 'placeholder': 'Enter your password'}}) }}
                    {{ form_errors(registrationForm.plainPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.second) }}
                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control', 'type': 'password', 'placeholder': 'Repeat your password'}}) }}
                    {{ form_errors(registrationForm.plainPassword.second) }}
                </div>

                <div class="checkbox-row">
                    {{ form_widget(registrationForm.agreeTerms, {'attr': {'id': 'agree_terms'}}) }}
                    <label for="agree_terms">I agree to the terms</label>
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="btn-register">
                    <i class="fa fa-user-plus"></i> Create Account
                </button>
            {{ form_end(registrationForm) }}

            <div class="login-link">
                <span>Already have an account?</span>
                <a href="{{ path('app_login') }}">Sign in</a>
            </div>
        </div>
    </div>
</body>
</html>
