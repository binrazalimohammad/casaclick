<script>
(function () {
  document.querySelectorAll('.westio-tabs').forEach(function (tablist) {
    var tabs = tablist.querySelectorAll('.westio-tab');
    var container = tablist.parentElement;
    var panels = [];
    if (tablist.closest('#spaces')) {
      panels = [
        document.getElementById('panel-lr'),
        document.getElementById('panel-kit'),
        document.getElementById('panel-bath'),
        document.getElementById('panel-bed')
      ];
    } else if (tablist.closest('#floorplans')) {
      panels = [
        document.getElementById('fplan-studio'),
        document.getElementById('fplan-1br'),
        document.getElementById('fplan-2br'),
        document.getElementById('fplan-ph')
      ];
    }
    tabs.forEach(function (tab, i) {
      tab.addEventListener('click', function () {
        tabs.forEach(function (t) { t.classList.remove('is-active'); });
        tab.classList.add('is-active');
        panels.forEach(function (p, j) {
          if (!p) return;
          p.classList.toggle('is-active', j === i);
        });
      });
    });
  });
})();
</script>
