{% extends 'base.html.twig' %}

{% block title %}Make Payment{% endblock %}

{% block body %}
<div class="page-container">
    <div class="form-wrapper">
        <div class="form-header">
            <i class="fa fa-credit-card form-icon"></i>
            <h1 class="form-title">Make Payment</h1>
        </div>

        <div class="form-card">
            <div class="alert alert-info">
                <strong>Application Details:</strong><br>
                <strong>Listing:</strong> {{ application.listing.name }}<br>
                <strong>Monthly Rent:</strong> ₱{{ application.listing.price|number_format(2, '.', ',') }}<br>
                <strong>Landlord:</strong> {{ application.landlord ? application.landlord.name : 'N/A' }}
            </div>

            <div class="alert alert-success" style="margin-bottom:20px">
                <strong>Pay online?</strong>
                <a href="{{ path('app_payment_paymongo_setup', {'id': application.id}) }}" class="btn-submit" style="display:inline-block;margin-top:8px;padding:10px 16px;background:#00a651;color:#fff;border-radius:8px;text-decoration:none">
                    Pay with Paymongo (GCash, Maya, or card)
                </a>
                <p style="margin:8px 0 0;font-size:0.9rem">You will choose your payment method and enter required details before checkout.</p>
            </div>

            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.amount) }}
                    {{ form_widget(form.amount, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.amount) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.paymentMethod) }}
                    {{ form_widget(form.paymentMethod, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.paymentMethod) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.transactionId) }}
                    {{ form_widget(form.transactionId, {'attr': {'class': 'form-control', 'placeholder': 'Optional: Enter transaction ID or reference number'}}) }}
                    {{ form_errors(form.transactionId) }}
                    <small class="form-text text-muted">Required for bank transfers, GCash, PayMaya, etc.</small>
                </div>

                <div class="form-group">
                    {{ form_label(form.notes) }}
                    {{ form_widget(form.notes, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                    {{ form_errors(form.notes) }}
                </div>

                <div class="form-actions">
                    <a href="{{ path('app_application_index') }}" class="btn-cancel">
                        <i class="fa fa-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn-submit">
                        <i class="fa fa-check"></i> Submit Payment
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>

<style>
    .page-container {
        background: linear-gradient(135deg, #F8F5EE 0%, #F0E6D2 100%);
        min-height: 100vh;
        padding: 40px 20px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .form-wrapper {
        width: 100%;
        max-width: 600px;
    }

    .form-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .form-icon {
        font-size: 48px;
        color: #8B4513;
        margin-bottom: 15px;
        display: block;
    }

    .form-title {
        color: #5C4033;
        font-size: 32px;
        font-weight: 800;
        margin: 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', sans-serif;
    }

    .form-card {
        background: #FFFDF7;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(210, 180, 140, 0.2);
    }

    .alert {
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        border: none;
        font-size: 14px;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .alert-info {
        background: #D1ECF1;
        color: #0C5460;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group label {
        color: #5C4033;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .form-control,
    .form-select {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #E8DCC0;
        border-radius: 10px;
        font-size: 15px;
        font-family: 'Nunito', 'Poppins', sans-serif;
        background: #FFFDF7;
        color: #5C4033;
        transition: all 0.3s ease;
    }

    .form-control:focus,
    .form-select:focus {
        outline: none;
        border-color: #8B4513;
        background: #FFFFFF;
        box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
    }

    .form-text {
        color: #8B7355;
        font-size: 13px;
        margin-top: 6px;
        display: block;
    }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 30px;
        padding-top: 24px;
        border-top: 1px solid #E8DCC0;
    }

    .btn-cancel {
        background: #F8F9FA;
        color: #5C4033;
        padding: 14px 32px;
        border: 2px solid #E8DCC0;
        border-radius: 10px;
        text-decoration: none;
        font-size: 15px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'Nunito', 'Poppins', sans-serif;
        flex: 1;
        justify-content: center;
    }

    .btn-cancel:hover {
        background: #E8DCC0;
        color: #3E2723;
        text-decoration: none;
        transform: translateY(-2px);
    }

    .btn-submit {
        background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
        color: white;
        padding: 14px 32px;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'Nunito', 'Poppins', sans-serif;
        box-shadow: 0 4px 15px rgba(139, 69, 19, 0.3);
        flex: 1;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
        background: linear-gradient(135deg, #A0522D 0%, #8B4513 100%);
    }

    @media (max-width: 768px) {
        .page-container {
            padding: 20px 15px;
        }

        .form-card {
            padding: 30px 20px;
        }

        .form-title {
            font-size: 28px;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-cancel,
        .btn-submit {
            width: 100%;
        }
    }
</style>
{% endblock %}

