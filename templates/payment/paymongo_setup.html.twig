{% extends 'base.html.twig' %}

{% block title %}Pay with Paymongo{% endblock %}

{% block body %}
<div class="page-container" style="max-width:560px;margin:0 auto;padding:20px">
    <a href="{{ path('app_application_index') }}" class="back-button" style="display:inline-flex;align-items:center;gap:8px;margin-bottom:16px;color:#5c4033;text-decoration:none">
        <i class="fa fa-arrow-left"></i> Back to bookings
    </a>

    <h1 style="font-size:1.5rem;margin:0 0 8px;color:#3e2723">Pay with Paymongo</h1>
    <p style="color:#666;margin:0 0 20px">Choose how you will pay, then enter the details required for that method.</p>

    <div class="alert alert-info" style="background:#fffdf7;border:1px solid #d2b48c;border-radius:8px;padding:14px;margin-bottom:20px">
        <strong>{{ application.listing.name }}</strong><br>
        Monthly rent: <strong>₱{{ default_amount|number_format(2, '.', ',') }}</strong>
    </div>

    <form method="post" id="paymongo-setup-form" class="form-card" style="background:#fff;border-radius:12px;padding:24px;border:1px solid #e8dfd0">
        <input type="hidden" name="paymentChannel" id="paymentChannel" value="{{ submitted.paymentChannel|default('') }}">

        <fieldset style="border:none;padding:0;margin:0 0 20px">
            <legend style="font-weight:600;margin-bottom:12px">1. Payment type</legend>
            <div id="category-options"></div>
        </fieldset>

        <fieldset id="channel-section" style="border:none;padding:0;margin:0 0 20px;display:none">
            <legend style="font-weight:600;margin-bottom:12px">2. Select method</legend>
            <div id="channel-options"></div>
        </fieldset>

        <fieldset id="requirements-section" style="border:none;padding:0;margin:0 0 20px;display:none">
            <legend style="font-weight:600;margin-bottom:12px">3. Your details</legend>
            <div id="requirements-fields"></div>
        </fieldset>

        <div class="form-group" style="margin-bottom:20px">
            <label for="amount" style="font-weight:500">Amount (PHP)</label>
            <input type="number" step="0.01" min="1" name="amount" id="amount" class="form-control"
                   value="{{ submitted.amount|default(default_amount) }}" required>
        </div>

        <button type="submit" class="btn-submit" style="width:100%;padding:14px;background:#00a651;color:#fff;border:none;border-radius:8px;font-weight:600;font-size:1rem;cursor:pointer">
            Continue to secure checkout
        </button>
    </form>
</div>

<script>
(function () {
    const schema = {{ options_json|raw }};
    const submitted = {{ submitted|json_encode|raw }};

    const categoryEl = document.getElementById('category-options');
    const channelSection = document.getElementById('channel-section');
    const channelEl = document.getElementById('channel-options');
    const reqSection = document.getElementById('requirements-section');
    const reqFields = document.getElementById('requirements-fields');
    const channelInput = document.getElementById('paymentChannel');

    let selectedCategory = null;
    let selectedChannel = null;

    function renderCategories() {
        categoryEl.innerHTML = '';
        schema.categories.forEach(cat => {
            const label = document.createElement('label');
            label.style.cssText = 'display:block;padding:12px;border:2px solid #e8dfd0;border-radius:8px;margin-bottom:8px;cursor:pointer';
            label.innerHTML = '<strong>' + cat.label + '</strong><br><span style="font-size:0.9rem;color:#666">' + cat.description + '</span>';
            const radio = document.createElement('input');
            radio.type = 'radio';
            radio.name = 'paymentCategory';
            radio.value = cat.id;
            radio.style.marginRight = '8px';
            radio.addEventListener('change', () => selectCategory(cat));
            label.prepend(radio);
            categoryEl.appendChild(label);
        });
    }

    function selectCategory(cat) {
        selectedCategory = cat;
        channelSection.style.display = 'block';
        channelEl.innerHTML = '';
        cat.channels.forEach(ch => {
            const label = document.createElement('label');
            label.style.cssText = 'display:block;padding:10px;border:1px solid #ddd;border-radius:8px;margin-bottom:6px;cursor:pointer';
            label.textContent = ch.label;
            const radio = document.createElement('input');
            radio.type = 'radio';
            radio.name = 'channelPick';
            radio.value = ch.id;
            radio.style.marginRight = '8px';
            radio.addEventListener('change', () => selectChannel(ch));
            label.prepend(radio);
            channelEl.appendChild(label);
        });
        if (submitted.paymentChannel) {
            const ch = cat.channels.find(c => c.id === submitted.paymentChannel);
            if (ch) {
                channelEl.querySelector('input[value="' + ch.id + '"]').checked = true;
                selectChannel(ch);
            }
        }
    }

    function selectChannel(ch) {
        selectedChannel = ch;
        channelInput.value = ch.id;
        reqSection.style.display = 'block';
        reqFields.innerHTML = '';
        ch.requirements.forEach(field => {
            const wrap = document.createElement('div');
            wrap.style.marginBottom = '12px';
            const lab = document.createElement('label');
            lab.textContent = field.label + (field.required ? ' *' : '');
            lab.style.display = 'block';
            lab.style.fontWeight = '500';
            lab.style.marginBottom = '4px';
            const input = document.createElement('input');
            input.name = field.key;
            input.className = 'form-control';
            input.type = field.type === 'phone' ? 'tel' : (field.type || 'text');
            if (field.placeholder) input.placeholder = field.placeholder;
            if (field.required) input.required = true;
            if (submitted[field.key]) input.value = submitted[field.key];
            wrap.appendChild(lab);
            wrap.appendChild(input);
            reqFields.appendChild(wrap);
        });
    }

    renderCategories();
    if (submitted.paymentChannel) {
        for (const cat of schema.categories) {
            if (cat.channels.some(c => c.id === submitted.paymentChannel)) {
                categoryEl.querySelector('input[value="' + cat.id + '"]').checked = true;
                selectCategory(cat);
                break;
            }
        }
    }
})();
</script>
{% endblock %}
