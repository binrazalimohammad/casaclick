{% extends 'base.html.twig' %}

{% block title %}Payment History{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .payment-history-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-title {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 28px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 15px;
        }

        .page-title-icon {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 8px;
            color: white;
            font-size: 18px;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            color: #495057;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            margin-bottom: 20px;
        }

        .back-button:hover {
            background: #e9ecef;
            border-color: #adb5bd;
            color: #212529;
            transform: translateX(-2px);
        }

        .info-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid #e9ecef;
        }

        .info-card-title {
            font-size: 16px;
            font-weight: 600;
            color: #495057;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 2px solid #f1f3f5;
        }

        .info-card-content {
            color: #6c757d;
            font-size: 14px;
        }

        .info-card-content p {
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .info-card-content strong {
            color: #2c3e50;
            font-weight: 600;
        }

        .status-badge {
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-badge.approved {
            background: #d4edda;
            color: #155724;
        }

        .status-badge.rejected {
            background: #f8d7da;
            color: #721c24;
        }

        .status-badge.pending {
            background: #fff3cd;
            color: #856404;
        }

        .amount-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 28px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid #e9ecef;
            text-align: center;
        }

        .amount-card-title {
            font-size: 16px;
            font-weight: 600;
            color: #6c757d;
            margin-bottom: 16px;
        }

        .amount-value {
            font-size: 36px;
            font-weight: 700;
            color: #2c3e50;
            margin: 0;
        }

        .payment-records-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid #e9ecef;
        }

        .payment-records-title {
            font-size: 18px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 2px solid #f1f3f5;
        }

        .payment-table {
            width: 100%;
            border-collapse: collapse;
        }

        .payment-table thead {
            background: #f8f9fa;
        }

        .payment-table th {
            padding: 12px;
            text-align: left;
            font-weight: 600;
            color: #495057;
            font-size: 14px;
            border-bottom: 2px solid #dee2e6;
        }

        .payment-table td {
            padding: 16px 12px;
            border-bottom: 1px solid #f1f3f5;
            color: #6c757d;
            font-size: 14px;
        }

        .payment-table tbody tr:hover {
            background: #f8f9fa;
        }

        .payment-table tbody tr:last-child td {
            border-bottom: none;
        }

        .payment-status-badge {
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .payment-status-badge.completed {
            background: #d4edda;
            color: #155724;
        }

        .payment-status-badge.failed {
            background: #f8d7da;
            color: #721c24;
        }

        .payment-status-badge.pending {
            background: #fff3cd;
            color: #856404;
        }

        .payment-status-badge.refunded {
            background: #d1ecf1;
            color: #0c5460;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #6c757d;
        }

        .empty-state-icon {
            font-size: 48px;
            color: #dee2e6;
            margin-bottom: 16px;
        }

        .empty-state-text {
            font-size: 16px;
            color: #adb5bd;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-action {
            padding: 6px 12px;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-action.approve {
            background: #28a745;
            color: white;
        }

        .btn-action.approve:hover {
            background: #218838;
        }

        .btn-action.reject {
            background: #dc3545;
            color: white;
        }

        .btn-action.reject:hover {
            background: #c82333;
        }

        @media (max-width: 768px) {
            .payment-history-container {
                padding: 15px;
            }

            .page-title {
                font-size: 24px;
            }

            .amount-value {
                font-size: 28px;
            }

            .payment-table {
                font-size: 12px;
            }

            .payment-table th,
            .payment-table td {
                padding: 8px;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="payment-history-container">
    <div class="page-header">
        <h1 class="page-title">
            <span class="page-title-icon">
                <i class="fa fa-money"></i>
            </span>
            Payment History
        </h1>
        <a href="{{ path('app_application_index') }}" class="back-button">
            <i class="fa fa-arrow-left"></i>
            Back to Applications
        </a>
    </div>

    <div class="info-card">
        <div class="info-card-title">Application Details</div>
        <div class="info-card-content">
            <p>
                <strong>Listing:</strong>
                <span>{{ application.listing.name }}</span>
            </p>
            <p>
                <strong>Monthly Rent:</strong>
                <span>₱{{ listingPrice|number_format(2, '.', ',') }}</span>
            </p>
            <p>
                <strong>Status:</strong>
                <span class="status-badge 
                    {% if application.status == 'approved' %}approved
                    {% elseif application.status == 'rejected' %}rejected
                    {% else %}pending{% endif %}">
                    {{ application.status|upper }}
                </span>
            </p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="amount-card">
                <div class="amount-card-title">Total Paid</div>
                <p class="amount-value">₱{{ totalPaid|number_format(2, '.', ',') }}</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="amount-card">
                <div class="amount-card-title">Remaining Balance</div>
                <p class="amount-value">₱{{ (listingPrice - totalPaid)|number_format(2, '.', ',') }}</p>
            </div>
        </div>
    </div>

    <div class="payment-records-card">
        <div class="payment-records-title">Payment Records</div>
        {% if payments|length > 0 %}
            <div class="table-responsive">
                <table class="payment-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            <th>Transaction ID</th>
                            <th>Status</th>
                            <th>Paid At</th>
                            {% if is_granted('ROLE_LANDLORD') %}
                                <th>Actions</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for payment in payments %}
                            <tr>
                                <td>{{ payment.createdAt|date('Y-m-d H:i') }}</td>
                                <td><strong>₱{{ payment.amount|number_format(2, '.', ',') }}</strong></td>
                                <td>
                                    <span style="color: #6c757d;">
                                        {{ payment.paymentMethod|replace({'_': ' '})|title }}
                                    </span>
                                </td>
                                <td>{{ payment.transactionId ?? 'N/A' }}</td>
                                <td>
                                    <span class="payment-status-badge 
                                        {% if payment.status == 'completed' %}completed
                                        {% elseif payment.status == 'failed' %}failed
                                        {% elseif payment.status == 'refunded' %}refunded
                                        {% else %}pending{% endif %}">
                                        {{ payment.status|upper }}
                                    </span>
                                </td>
                                <td>{{ payment.paidAt ? payment.paidAt|date('Y-m-d H:i') : 'Pending' }}</td>
                                {% if is_granted('ROLE_LANDLORD') %}
                                    <td>
                                        {% if payment.status == 'pending' %}
                                            <div class="action-buttons">
                                                <form method="post" action="{{ path('app_payment_approve', {'id': payment.id}) }}" style="display: inline;">
                                                    <button type="submit" class="btn-action approve" onclick="return confirm('Approve this payment?')">
                                                        <i class="fa fa-check"></i> Approve
                                                    </button>
                                                </form>
                                                <form method="post" action="{{ path('app_payment_reject', {'id': payment.id}) }}" style="display: inline;">
                                                    <button type="submit" class="btn-action reject" onclick="return confirm('Reject this payment?')">
                                                        <i class="fa fa-times"></i> Reject
                                                    </button>
                                                </form>
                                            </div>
                                        {% else %}
                                            <span style="color: #adb5bd;">—</span>
                                        {% endif %}
                                    </td>
                                {% endif %}
                            </tr>
                            {% if payment.notes %}
                                <tr>
                                    <td colspan="{% if is_granted('ROLE_LANDLORD') %}7{% else %}6{% endif %}" style="color: #6c757d; font-size: 13px; padding-left: 12px;">
                                        <strong>Notes:</strong> {{ payment.notes }}
                                    </td>
                                </tr>
                            {% endif %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa fa-inbox"></i>
                </div>
                <div class="empty-state-text">No payment records found</div>
            </div>
        {% endif %}
    </div>

    {% if application.status == 'approved' and not is_granted('ROLE_LANDLORD') %}
        <div style="text-align: center; margin-top: 30px;">
            <a href="{{ path('app_payment_new', {'id': application.id}) }}" class="btn btn-success" style="padding: 12px 30px; font-size: 16px; font-weight: 600; border-radius: 8px;">
                <i class="fa fa-credit-card"></i> Make Payment
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}

