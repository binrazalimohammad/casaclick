{% extends 'base_public.html.twig' %}

{% block title %}About Us - CasaClick{% endblock %}

{% block body %}
<div class="about-propeble">
  {# Page hero — inner title bar style #}
  <header class="about-propeble__hero">
    <p class="about-propeble__eyebrow">About</p>
    <h1 class="about-propeble__title">Who we are</h1>
    <p class="about-propeble__lead">We connect tenants with verified apartments and landlords with qualified applicants—built on trust, clarity, and care.</p>
  </header>

  {# Trio: Who / Vision / Mission #}
  <section class="about-propeble__trio" aria-labelledby="about-trio-heading">
    <h2 id="about-trio-heading" class="visually-hidden">Company overview</h2>
    <div class="about-propeble__trio-grid">
      <article class="about-propeble__card">
        <h3 class="about-propeble__card-title">Who we are</h3>
        <p class="about-propeble__card-text">CasaClick is a rental platform focused on verified listings and a smoother path from search to move-in—for tenants and landlords alike.</p>
      </article>
      <article class="about-propeble__card">
        <h3 class="about-propeble__card-title">Our vision</h3>
        <p class="about-propeble__card-text">A rental market where every listing is trustworthy, every application is straightforward, and finding home feels human—not overwhelming.</p>
      </article>
      <article class="about-propeble__card">
        <h3 class="about-propeble__card-title">Our mission</h3>
        <p class="about-propeble__card-text">We simplify the rental process with verification, clear communication, and tools that help good landlords meet great tenants.</p>
      </article>
    </div>
  </section>

  {# Story band + image split #}
  <section class="about-propeble__story">
    <div class="about-propeble__story-media">
      <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&amp;fit=crop&amp;w=800&amp;q=75" alt="" loading="lazy" width="800" height="600">
    </div>
    <div class="about-propeble__story-body">
      <blockquote class="about-propeble__quote">From first search to move-in day, our properties are the backdrop to your story.</blockquote>
      <p class="about-propeble__story-copy">CasaClick was founded to remove friction from renting: fewer surprises, clearer expectations, and support when you need it.</p>
      <a href="{{ path('app_contact') }}" class="about-propeble__btn">Read more details</a>
    </div>
  </section>

  {# Listing highlights carousel #}
  <section class="about-propeble__highlights" aria-labelledby="highlights-heading">
    <div class="about-propeble__highlights-intro">
      <p class="about-propeble__highlights-kicker">Featured on CasaClick</p>
      <h2 id="highlights-heading" class="about-propeble__highlights-h2">Highlights from our listings</h2>
      <p class="about-propeble__highlights-lead">A rotating look at real homes on the platform—verified photos and clear details.</p>
    </div>
    <div
      class="about-propeble__highlights-shell js-about-highlights"
      data-slide-count="{{ highlightSlides|length }}"
      style="--slide-count: {{ highlightSlides|length }};"
      tabindex="0"
    >
      <div class="about-propeble__highlights-viewport">
        <div class="about-propeble__highlights-track" style="--index: 0;">
          {% for slide in highlightSlides %}
          {% set bgUrl = slide.image ? asset(slide.image) : (slide.fallbackImage ?? 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1600&q=75') %}
          <article class="about-propeble__highlights-slide" aria-roledescription="slide" {% if not loop.first %}aria-hidden="true"{% endif %} data-slide-index="{{ loop.index0 }}">
            <div class="about-propeble__highlights-bg" style="background-image: url('{{ bgUrl|e('html_attr') }}');"></div>
            <div class="about-propeble__highlights-scrim" aria-hidden="true"></div>
            <div class="about-propeble__highlights-panel">
              <p class="about-propeble__highlights-tag">{{ slide.source == 'listing' ? 'Live listing' : 'Spotlight' }}</p>
              <h3 class="about-propeble__highlights-name">{{ slide.title }}</h3>
              <p class="about-propeble__highlights-meta">{{ slide.line1 }}</p>
              <p class="about-propeble__highlights-price">{{ slide.line2 }}</p>
              {% if slide.source == 'listing' and slide.id %}
              <a href="{{ path('app_product_show', {id: slide.id}) }}" class="about-propeble__highlights-cta">View listing</a>
              {% else %}
              <a href="{{ path('app_product_index') }}" class="about-propeble__highlights-cta">Browse listings</a>
              {% endif %}
            </div>
          </article>
          {% endfor %}
        </div>
      </div>
      {% if highlightSlides|length > 1 %}
      <button type="button" class="about-propeble__highlights-arrow about-propeble__highlights-arrow--prev" aria-label="Previous slide">
        <i class="fa fa-angle-left" aria-hidden="true"></i>
      </button>
      <button type="button" class="about-propeble__highlights-arrow about-propeble__highlights-arrow--next" aria-label="Next slide">
        <i class="fa fa-angle-right" aria-hidden="true"></i>
      </button>
      <div class="about-propeble__highlights-dots" role="tablist" aria-label="Slides">
        {% for slide in highlightSlides %}
        <button type="button" class="about-propeble__highlights-dot{% if loop.first %} is-active{% endif %}" role="tab" aria-selected="{{ loop.first ? 'true' : 'false' }}" aria-label="Slide {{ loop.index }}" data-slide-to="{{ loop.index0 }}"></button>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </section>

  {# Stats counters #}
  <section class="about-propeble__stats" aria-label="CasaClick in numbers">
    <div class="about-propeble__stats-grid">
      <div class="about-propeble__stat">
        <span class="about-propeble__stat-num">500+</span>
        <span class="about-propeble__stat-label">Active listings</span>
      </div>
      <div class="about-propeble__stat">
        <span class="about-propeble__stat-num">1.2k+</span>
        <span class="about-propeble__stat-label">Happy tenants</span>
      </div>
      <div class="about-propeble__stat">
        <span class="about-propeble__stat-num">5+</span>
        <span class="about-propeble__stat-label">Years of service</span>
      </div>
      <div class="about-propeble__stat">
        <span class="about-propeble__stat-num">50+</span>
        <span class="about-propeble__stat-label">Areas covered</span>
      </div>
    </div>
  </section>

  {# Appointment CTA #}
  <section class="about-propeble__appointment">
    <div class="about-propeble__appointment-inner">
      <h2 class="about-propeble__appointment-title">Schedule time with us—we’ll help you find the right fit</h2>
      <p class="about-propeble__appointment-text">Tell us what you need: browsing listings, listing a property, or support along the way. We’re here to help.</p>
      <a href="{{ path('app_contact') }}" class="about-propeble__btn about-propeble__btn--inverse">Contact us</a>
    </div>
  </section>

  {# Team — “Meet with our agents” style #}
  <section class="about-propeble__team" id="team">
    <p class="about-propeble__section-eyebrow">Our people</p>
    <h2 class="about-propeble__section-title">Meet the team</h2>
    <div class="about-propeble__team-grid">
      {% for member in team %}
      <article class="about-propeble__agent">
        {% if member.photo is defined and member.photo %}
        <div class="about-propeble__agent-avatar about-propeble__agent-avatar--photo">
          <img src="{{ asset(member.photo) }}" alt="{{ member.name }}, {{ member.position }}" loading="lazy" decoding="async" width="400" height="300">
        </div>
        {% else %}
        <div class="about-propeble__agent-avatar" aria-hidden="true">{{ member.name|slice(0, 1) }}</div>
        {% endif %}
        <div class="about-propeble__agent-body">
          <h3 class="about-propeble__agent-name">{{ member.name }}</h3>
          <p class="about-propeble__agent-role">{{ member.position }}</p>
          <p class="about-propeble__agent-bio">{{ member.bio }}</p>
          {% set s = member.social|default({}) %}
          {% set hasSocial = s.linkedin|default('')|trim or s.facebook|default('')|trim or s.instagram|default('')|trim or s.email|default('')|trim %}
          <div class="about-propeble__agent-social" aria-label="Social links for {{ member.name }}">
            {% if s.linkedin|default('')|trim %}
            <a class="about-propeble__social-link" href="{{ s.linkedin }}" target="_blank" rel="noopener noreferrer" title="LinkedIn — {{ member.name }}"><i class="fa fa-linkedin" aria-hidden="true"></i><span class="visually-hidden">LinkedIn</span></a>
            {% endif %}
            {% if s.facebook|default('')|trim %}
            <a class="about-propeble__social-link" href="{{ s.facebook }}" target="_blank" rel="noopener noreferrer" title="Facebook — {{ member.name }}"><i class="fa fa-facebook" aria-hidden="true"></i><span class="visually-hidden">Facebook</span></a>
            {% endif %}
            {% if s.instagram|default('')|trim %}
            <a class="about-propeble__social-link" href="{{ s.instagram }}" target="_blank" rel="noopener noreferrer" title="Instagram — {{ member.name }}"><i class="fa fa-instagram" aria-hidden="true"></i><span class="visually-hidden">Instagram</span></a>
            {% endif %}
            {% if s.email|default('')|trim %}
            <a class="about-propeble__social-link" href="{{ s.email starts with 'mailto:' ? s.email : 'mailto:' ~ s.email }}" title="Email {{ member.name }}"><i class="fa fa-envelope" aria-hidden="true"></i><span class="visually-hidden">Email</span></a>
            {% endif %}
            {% if not hasSocial %}
            <a class="about-propeble__social-link about-propeble__social-link--fallback" href="{{ path('app_contact') }}" title="Contact CasaClick about {{ member.name }}"><i class="fa fa-envelope" aria-hidden="true"></i><span class="visually-hidden">Contact</span></a>
            {% endif %}
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
  </section>

  {# Bottom CTA strip #}
  <section class="about-propeble__bottom-cta" aria-labelledby="bottom-cta-heading">
    <div class="about-propeble__bottom-inner">
      <div class="about-propeble__bottom-card">
        <div class="about-propeble__bottom-copy">
          <p class="about-propeble__bottom-eyebrow">Move in with confidence</p>
          <h2 id="bottom-cta-heading" class="about-propeble__bottom-title">Small details shouldn’t stop your move.</h2>
          <p class="about-propeble__bottom-text">Start with CasaClick—browse verified listings or list your property in minutes.</p>
        </div>
        <div class="about-propeble__bottom-actions">
          <a href="{{ path('app_register') }}" class="about-propeble__btn about-propeble__btn--solid about-propeble__btn--cta">Get started</a>
          <ul class="about-propeble__bullets">
            <li><span class="about-propeble__bullet-check" aria-hidden="true"></span>Free to sign up</li>
            <li><span class="about-propeble__bullet-check" aria-hidden="true"></span>Support when you need it</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {# FAQ — accordion style #}
  <section class="about-propeble__faq" aria-labelledby="faq-heading">
    <p class="about-propeble__section-eyebrow">Help center</p>
    <h2 id="faq-heading" class="about-propeble__section-title">More information</h2>
    <div class="about-propeble__faq-list">
      <details class="about-propeble__details">
        <summary>How does CasaClick verify listings?</summary>
        <p>We work with landlords to confirm details and encourage accurate photos and descriptions so you know what you’re getting before you visit.</p>
      </details>
      <details class="about-propeble__details">
        <summary>Is CasaClick free for tenants?</summary>
        <p>Browsing and creating an account is free. Any fees depend on your landlord or building—always shown clearly in the listing flow.</p>
      </details>
      <details class="about-propeble__details">
        <summary>How do landlords get started?</summary>
        <p>Register, complete your profile, and submit listings for review. Our team helps keep quality high for everyone on the platform.</p>
      </details>
    </div>
  </section>
</div>

<style>
/* CasaClick palette: --cc-brown #5c4033, --cc-gold #8B4513, --cc-sienna #A0522D, --cc-tan #D2B48C, --cc-cream #FFFDF7, --cc-soft #f9f7f4 */
.about-propeble {
  --ab-brown: #5c4033;
  --ab-gold: #8B4513;
  --ab-sienna: #A0522D;
  --ab-tan: #D2B48C;
  --ab-cream: #FFFDF7;
  --ab-soft: #f9f7f4;
  --ab-white: #ffffff;
  --ab-text: #3e2723;
  --ab-muted: #6d4c41;
  --ab-line: rgba(92, 64, 51, 0.12);
  font-family: 'Nunito', 'Poppins', system-ui, sans-serif;
  color: var(--ab-text);
  background: var(--ab-cream);
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* Hero */
.about-propeble__hero {
  text-align: center;
  padding: 3.5rem 1.5rem 3rem;
  max-width: 720px;
  margin: 0 auto;
}
.about-propeble__eyebrow {
  font-size: 0.75rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--ab-gold);
  font-weight: 700;
  margin: 0 0 0.75rem;
}
.about-propeble__title {
  font-size: clamp(2rem, 4vw, 2.75rem);
  font-weight: 800;
  color: var(--ab-brown);
  margin: 0 0 1rem;
  line-height: 1.15;
}
.about-propeble__lead {
  margin: 0;
  font-size: 1.1rem;
  color: var(--ab-muted);
  line-height: 1.65;
}

/* Trio cards */
.about-propeble__trio {
  padding: 0 1.5rem 3.5rem;
  max-width: 1140px;
  margin: 0 auto;
}
.about-propeble__trio-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.about-propeble__card {
  background: var(--ab-white);
  border: 1px solid var(--ab-line);
  border-radius: 12px;
  padding: 1.75rem 1.5rem;
  box-shadow: 0 8px 30px rgba(92, 64, 51, 0.06);
  transition: box-shadow 0.25s, border-color 0.25s;
}
.about-propeble__card:hover {
  border-color: rgba(139, 69, 19, 0.22);
  box-shadow: 0 12px 36px rgba(92, 64, 51, 0.1);
}
.about-propeble__card-title {
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--ab-brown);
  margin: 0 0 0.75rem;
  padding-bottom: 0.75rem;
  border-bottom: 2px solid var(--ab-tan);
  display: inline-block;
  width: 100%;
}
.about-propeble__card-text {
  margin: 0;
  font-size: 0.95rem;
  color: var(--ab-muted);
  line-height: 1.65;
}

/* Story split */
.about-propeble__story {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
  align-items: stretch;
  background: var(--ab-soft);
  border-top: 1px solid var(--ab-line);
  border-bottom: 1px solid var(--ab-line);
}
.about-propeble__story-media {
  min-height: 320px;
}
.about-propeble__story-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  min-height: 320px;
}
.about-propeble__story-body {
  padding: 3rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.about-propeble__quote {
  font-size: clamp(1.25rem, 2.2vw, 1.5rem);
  font-weight: 700;
  color: var(--ab-brown);
  line-height: 1.45;
  margin: 0 0 1rem;
  padding: 0;
  border: none;
  font-style: normal;
}
.about-propeble__story-copy {
  margin: 0 0 1.5rem;
  color: var(--ab-muted);
  line-height: 1.7;
  font-size: 1rem;
}
.about-propeble__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
  padding: 0.85rem 1.75rem;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 8px;
  border: 2px solid var(--ab-gold);
  color: var(--ab-gold);
  background: transparent;
  transition: background 0.2s, color 0.2s;
}
.about-propeble__btn:hover {
  background: linear-gradient(135deg, var(--ab-gold), var(--ab-sienna));
  color: #fff;
  border-color: transparent;
}

/* Listing highlights carousel */
.about-propeble__highlights {
  padding: 3.5rem 1.5rem 4rem;
  background: var(--ab-soft);
  border-top: 1px solid var(--ab-line);
  border-bottom: 1px solid var(--ab-line);
}
.about-propeble__highlights-intro {
  max-width: 720px;
  margin: 0 auto 2rem;
  text-align: center;
}
.about-propeble__highlights-kicker {
  margin: 0 0 0.5rem;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--ab-gold);
}
.about-propeble__highlights-h2 {
  margin: 0 0 0.65rem;
  font-size: clamp(1.6rem, 3vw, 2.1rem);
  font-weight: 800;
  color: var(--ab-brown);
  line-height: 1.2;
}
.about-propeble__highlights-lead {
  margin: 0;
  font-size: 1.02rem;
  color: var(--ab-muted);
  line-height: 1.55;
}
.about-propeble__highlights-shell {
  position: relative;
  max-width: 1120px;
  margin: 0 auto;
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 0 20px 50px rgba(92, 64, 51, 0.14);
  outline: none;
}
.about-propeble__highlights-shell:focus-visible {
  box-shadow: 0 20px 50px rgba(92, 64, 51, 0.14), 0 0 0 3px rgba(139, 69, 19, 0.35);
}
.about-propeble__highlights-viewport {
  overflow: hidden;
  width: 100%;
  background: #2a211c;
}
.about-propeble__highlights-track {
  --index: 0;
  display: flex;
  width: calc(var(--slide-count, 1) * 100%);
  transform: translateX(calc(-1 * var(--index) * 100% / var(--slide-count, 1)));
  transition: transform 0.6s cubic-bezier(0.33, 1, 0.68, 1);
  will-change: transform;
}
.about-propeble__highlights-slide {
  position: relative;
  flex: 0 0 calc(100% / var(--slide-count, 1));
  min-height: min(52vh, 520px);
  max-height: 560px;
  display: flex;
  align-items: flex-end;
}
.about-propeble__highlights-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
}
.about-propeble__highlights-scrim {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(40, 28, 22, 0.15) 0%,
    rgba(40, 28, 22, 0.55) 55%,
    rgba(40, 28, 22, 0.88) 100%
  );
  pointer-events: none;
}
.about-propeble__highlights-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 2.5rem 2rem 2.75rem;
  text-align: left;
  max-width: 520px;
}
@media (min-width: 768px) {
  .about-propeble__highlights-panel {
    padding: 3rem 3rem 3.25rem;
  }
}
.about-propeble__highlights-tag {
  margin: 0 0 0.5rem;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #e8d4c4;
}
.about-propeble__highlights-name {
  margin: 0 0 0.4rem;
  font-size: clamp(1.45rem, 3vw, 2rem);
  font-weight: 800;
  color: #fffdf7;
  line-height: 1.2;
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
}
.about-propeble__highlights-meta {
  margin: 0 0 0.35rem;
  font-size: 1rem;
  color: rgba(255, 253, 247, 0.92);
  line-height: 1.45;
}
.about-propeble__highlights-price {
  margin: 0 0 1.25rem;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ab-tan);
  letter-spacing: 0.02em;
}
.about-propeble__highlights-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.9rem 1.6rem;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 8px;
  background: #fffdf7;
  color: var(--ab-brown) !important;
  border: 1px solid rgba(255, 253, 247, 0.95);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
  transition: background 0.2s, transform 0.2s;
}
.about-propeble__highlights-cta:hover {
  background: var(--ab-tan);
  color: var(--ab-brown) !important;
  transform: translateY(-2px);
}
.about-propeble__highlights-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 1px solid rgba(255, 253, 247, 0.35);
  background: rgba(40, 28, 22, 0.45);
  color: #fffdf7;
  font-size: 1.35rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, border-color 0.2s;
}
.about-propeble__highlights-arrow:hover {
  background: rgba(255, 253, 247, 0.18);
  border-color: rgba(255, 253, 247, 0.55);
}
.about-propeble__highlights-arrow--prev { left: 12px; }
.about-propeble__highlights-arrow--next { right: 12px; }
.about-propeble__highlights-dots {
  position: absolute;
  bottom: 14px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  gap: 8px;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(40, 28, 22, 0.4);
  backdrop-filter: blur(6px);
}
.about-propeble__highlights-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: none;
  padding: 0;
  background: rgba(255, 253, 247, 0.35);
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.about-propeble__highlights-dot.is-active {
  background: #fffdf7;
  transform: scale(1.2);
}
@media (max-width: 600px) {
  .about-propeble__highlights-arrow {
    width: 40px;
    height: 40px;
    font-size: 1.15rem;
  }
  .about-propeble__highlights-arrow--prev { left: 8px; }
  .about-propeble__highlights-arrow--next { right: 8px; }
  .about-propeble__highlights-slide {
