{% extends 'base.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block body %}
<div class="page-container">
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa fa-key"></i> Change Password
            </h1>
            <p class="page-subtitle">Update your account password</p>
        </div>
        <a href="{{ path('app_account_show') }}" class="btn-back">
            <i class="fa fa-arrow-left"></i> Back to Profile
        </a>
    </div>

    <div class="content-card">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="form-section">
            {{ form_start(form, {'attr': {'class': 'password-form'}}) }}
                
                <div class="form-group">
                    {{ form_label(form.currentPassword, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.currentPassword, {'attr': {'class': 'form-control', 'type': 'password', 'placeholder': 'Enter your current password'}}) }}
                    {{ form_errors(form.currentPassword) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.newPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.newPassword.first, {'attr': {'class': 'form-control', 'type': 'password', 'placeholder': 'Enter your new password'}}) }}
                    {{ form_errors(form.newPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.newPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.newPassword.second, {'attr': {'class': 'form-control', 'type': 'password', 'placeholder': 'Repeat your new password'}}) }}
                    {{ form_errors(form.newPassword.second) }}
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-update">
                        <i class="fa fa-check"></i> Update Password
                    </button>
                    <a href="{{ path('app_account_show') }}" class="btn-cancel">
                        <i class="fa fa-times"></i> Cancel
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<style>
    .page-container { min-height: 100vh; padding: 32px 20px; }
    .page-header {
        max-width: 700px;
        margin: 0 auto 20px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }
    .page-title {
        margin: 0;
        font-size: clamp(1.7rem, 2.8vw, 2.2rem);
        font-weight: 800;
        display: flex;
        gap: 10px;
        align-items: center;
    }
    .page-subtitle { margin-top: 6px; font-size: 0.95rem; }
    .content-card {
        max-width: 700px;
        margin: 0 auto;
        padding: 28px;
    }
    .password-form { display: grid; gap: 18px; }
    .form-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 6px;
    }
    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 6px;
        padding-top: 16px;
        border-top: 1px solid #e4e7ec;
    }
    .btn-update,
    .btn-cancel { flex: 1; justify-content: center; }
    @media (max-width: 768px) {
        .page-container { padding: 16px; }
        .content-card { padding: 18px; }
        .form-actions { flex-direction: column; }
    }
</style>
{% endblock %}
