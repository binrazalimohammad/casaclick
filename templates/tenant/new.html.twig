{% extends 'base.html.twig' %}

{% block title %}Create New Tenant{% endblock %}

{% block body %}
<div class="page-container">
    <div class="form-header">
        <i class="ti-file form-icon"></i>
        <h1 class="form-title">Create New Tenant</h1>
    </div>

    <div class="form-container">
        {{ include('tenant/_form.html.twig', {'button_label': 'Save'}) }}
    </div>

    <div class="back-button-container">
        <a href="{{ path('app_tenant') }}" class="back-button">
            <i class="ti-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<style>
    .page-container {
        background-color: #F8F5EE;
        min-height: 100vh;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .form-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .form-icon {
        font-size: 48px;
        color: #5C4033;
        margin-bottom: 15px;
        display: block;
    }

    .form-title {
        color: #5C4033;
        font-size: 32px;
        font-weight: 800;
        margin: 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        text-align: center;
        letter-spacing: -0.5px;
    }

    .form-container {
        background-color: #FFFDF7;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(210, 180, 140, 0.2);
        max-width: 600px;
        width: 100%;
        margin-bottom: 30px;
    }

    .back-button-container {
        text-align: center;
    }

    .back-button {
        background-color: #6B3E1A;
        color: white;
        padding: 12px 30px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 16px;
        transition: all 0.3s ease;
        display: inline-block;
        box-shadow: 0 4px 12px rgba(107, 62, 26, 0.3);
    }

    .back-button:hover {
        background-color: #5A3417;
        color: white;
        text-decoration: none;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(107, 62, 26, 0.4);
    }

    @media (max-width: 768px) {
        .page-container {
            padding: 20px 15px;
        }
        
        .form-container {
            padding: 30px 20px;
        }
        
        .form-title {
            font-size: 28px;
        }
        
        .form-icon {
            font-size: 40px;
        }
    }
</style>
{% endblock %}

