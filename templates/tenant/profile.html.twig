{% extends 'base.html.twig' %}

{% block title %}My Tenant Profile{% endblock %}

{% block body %}
<div class="page-container">
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa fa-user"></i> My Tenant Profile
            </h1>
            <p class="page-subtitle">View and manage your tenant profile information</p>
        </div>
        <a href="{{ path('app_tenant_profile_edit') }}" class="btn-edit-profile">
            <i class="fa fa-edit"></i> Edit Profile
        </a>
    </div>

    <div class="content-card">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="profile-section">
            <div class="profile-header">
                <div class="profile-avatar">
                    {% if tenant.photo %}
                        <img src="{{ asset('uploads/images/' ~ tenant.photo) }}" alt="{{ tenant.name }}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                    {% else %}
                        <i class="fa fa-user"></i>
                    {% endif %}
                </div>
                <div class="profile-info">
                    <h2 class="profile-name">{{ tenant.name }}</h2>
                    <p class="profile-email">{{ tenant.email }}</p>
                </div>
            </div>

            <div class="profile-details">
                <div class="info-item">
                    <div class="info-label">
                        <i class="fa fa-phone"></i> Phone
                    </div>
                    <div class="info-value">{{ tenant.phone }}</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa fa-map-marker-alt"></i> Address
                    </div>
                    <div class="info-value">{{ tenant.address ?: 'No address provided' }}</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fa fa-credit-card"></i> Mode of Payment
                    </div>
                    <div class="info-value">
                        {% if tenant.modeOfPayment %}
                            {{ tenant.modeOfPayment|replace({'_': ' '})|title }}
                        {% else %}
                            Not specified
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .page-container {
        background: linear-gradient(135deg, #F8F5EE 0%, #F0E6D2 100%);
        min-height: 100vh;
        padding: 40px 20px;
    }

    .page-header {
        max-width: 900px;
        margin: 0 auto 30px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        color: #5C4033;
        font-size: 36px;
        font-weight: 800;
        margin: 0 0 8px 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', sans-serif;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-title i {
        color: #8B4513;
        font-size: 32px;
    }

    .page-subtitle {
        color: #8B7355;
        font-size: 14px;
        margin: 0;
    }

    .btn-edit-profile {
        background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(139, 69, 19, 0.3);
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .btn-edit-profile:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(139, 69, 19, 0.4);
        background: linear-gradient(135deg, #A0522D 0%, #8B4513 100%);
        color: white;
        text-decoration: none;
    }

    .content-card {
        background: #FFFDF7;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(210, 180, 140, 0.2);
        max-width: 900px;
        margin: 0 auto;
    }

    .alert {
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        border: none;
        font-size: 14px;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .alert-success {
        background: #D4EDDA;
        color: #155724;
    }

    .alert-error,
    .alert-danger {
        background: #F8D7DA;
        color: #721C24;
    }

    .profile-section {
        margin-top: 20px;
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 24px;
        padding-bottom: 32px;
        margin-bottom: 32px;
        border-bottom: 2px solid #E8DCC0;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        color: white;
        box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
        flex-shrink: 0;
    }

    .profile-info {
        flex: 1;
    }

    .profile-name {
        font-size: 28px;
        font-weight: 700;
        color: #5C4033;
        margin: 0 0 8px 0;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .profile-email {
        font-size: 16px;
        color: #8B7355;
        margin: 0;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .profile-details {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .info-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding-bottom: 24px;
        border-bottom: 1px solid #E8DCC0;
    }

    .info-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .info-label {
        color: #8B7355;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .info-label i {
        color: #A0825C;
        font-size: 14px;
    }

    .info-value {
        color: #5C4033;
        font-size: 16px;
        font-weight: 500;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    @media (max-width: 768px) {
        .page-container {
            padding: 20px 15px;
        }

        .content-card {
            padding: 24px 16px;
        }

        .page-title {
            font-size: 28px;
        }

        .page-header {
            flex-direction: column;
        }

        .btn-edit-profile {
            width: 100%;
            justify-content: center;
        }

        .profile-header {
            flex-direction: column;
            text-align: center;
        }

        .profile-avatar {
            margin: 0 auto;
        }
    }
</style>
{% endblock %}

