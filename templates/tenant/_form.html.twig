{{ form_start(form, {
    'attr': {
        'class': 'tenant-form'
    }
}) }}

    <div class="form-fields">
        <div class="form-group">
            {{ form_label(form.name, 'Name', {
                'label_attr': {
                    'class': 'field-label'
                }
            }) }}
            {{ form_widget(form.name, {
                'attr': {
                    'class': 'form-input',
                    'placeholder': 'Enter full name'
                }
            }) }}
            {{ form_errors(form.name) }}
        </div>

        <div class="form-group">
            {{ form_label(form.email, 'Email', {
                'label_attr': {
                    'class': 'field-label'
                }
            }) }}
            {{ form_widget(form.email, {
                'attr': {
                    'class': 'form-input' ~ (form.email.vars.disabled ? ' form-input-disabled' : ''),
                    'placeholder': 'email@example.com',
                    'readonly': form.email.vars.disabled
                }
            }) }}
            {{ form_errors(form.email) }}
            {% if form.email.vars.help %}
                <small class="form-help-text">{{ form.email.vars.help }}</small>
            {% endif %}
        </div>

        <div class="form-group">
            {{ form_label(form.phone, 'Phone', {
                'label_attr': {
                    'class': 'field-label'
                }
            }) }}
            {{ form_widget(form.phone, {
                'attr': {
                    'class': 'form-input',
                    'placeholder': '+63 900 000 0000'
                }
            }) }}
            {{ form_errors(form.phone) }}
        </div>

        <div class="form-group">
            {{ form_label(form.address, 'Address', {
                'label_attr': {
                    'class': 'field-label'
                }
            }) }}
            {{ form_widget(form.address, {
                'attr': {
                    'class': 'form-input address-field',
                    'placeholder': 'Street, City, ZIP'
                }
            }) }}
            {{ form_errors(form.address) }}
        </div>

        <div class="form-group">
            {{ form_label(form.modeOfPayment, 'Mode of Payment', {
                'label_attr': {
                    'class': 'field-label'
                }
            }) }}
            {{ form_widget(form.modeOfPayment, {
                'attr': {
                    'class': 'form-input'
                }
            }) }}
            {{ form_errors(form.modeOfPayment) }}
        </div>

        <div class="form-group">
            {{ form_label(form.photo, 'Photo', {
                'label_attr': {
                    'class': 'field-label'
                }
            }) }}
            <div class="file-input-container">
                {{ form_widget(form.photo, {
                    'attr': {
                        'class': 'file-input',
                        'accept': 'image/*'
                    }
                }) }}
            </div>
            {{ form_errors(form.photo) }}
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="save-button">
            <i class="ti-save"></i> {{ button_label|default('Save') }}
        </button>
    </div>

{{ form_end(form) }}

<style>
    .tenant-form {
        width: 100%;
    }

    .form-fields {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .field-label {
        color: #5C4033;
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 8px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .form-input {
        background-color: white;
        border: 1px solid #D2B48C;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 16px;
        color: #5C4033;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        transition: all 0.3s ease;
        outline: none;
    }

    .form-input:focus {
        border-color: #8B4513;
        box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
    }

    .form-input::placeholder {
        color: #A9A9A9;
        font-weight: 400;
    }

    .address-field {
        min-height: 80px;
        resize: vertical;
    }

    .file-input-container {
        position: relative;
    }

    .file-input {
        background-color: white;
        border: 1px solid #D2B48C;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 16px;
        color: #5C4033;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        transition: all 0.3s ease;
        outline: none;
        width: 100%;
        cursor: pointer;
    }

    .file-input:focus {
        border-color: #8B4513;
        box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
    }

    .file-input:hover {
        border-color: #8B4513;
    }

    .form-input-disabled {
        background-color: #f5f5f5;
        cursor: not-allowed;
        opacity: 0.7;
    }

    .form-help-text {
        display: block;
        margin-top: 6px;
        font-size: 13px;
        color: #8B7355;
        font-style: italic;
    }

    .form-actions {
        text-align: center;
        margin-top: 30px;
    }

    .save-button {
        background-color: #8B4513;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 30px;
        font-size: 16px;
        font-weight: 600;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
    }

    .save-button:hover {
        background-color: #A0522D;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(139, 69, 19, 0.4);
    }

    .save-button:active {
        transform: translateY(0);
    }

    @media (max-width: 768px) {
        .form-input {
            font-size: 16px; /* Prevents zoom on iOS */
        }
    }
</style>
