{% extends 'base.html.twig' %}

{% block title %}Edit My Tenant Profile{% endblock %}

{% block body %}
<div class="page-container">
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="fa fa-edit"></i> Edit My Tenant Profile
            </h1>
            <p class="page-subtitle">Update your tenant profile information</p>
        </div>
        <a href="{{ path('app_tenant_profile') }}" class="btn-back">
            <i class="fa fa-arrow-left"></i> Back to Profile
        </a>
    </div>

    <div class="content-card">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="form-section">
            {{ include('tenant/_form.html.twig', {'button_label': 'Update Profile'}) }}
        </div>
    </div>
</div>

<style>
    .page-container {
        background: linear-gradient(135deg, #F8F5EE 0%, #F0E6D2 100%);
        min-height: 100vh;
        padding: 40px 20px;
    }

    .page-header {
        max-width: 900px;
        margin: 0 auto 30px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        color: #5C4033;
        font-size: 36px;
        font-weight: 800;
        margin: 0 0 8px 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', sans-serif;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-title i {
        color: #8B4513;
        font-size: 32px;
    }

    .page-subtitle {
        color: #8B7355;
        font-size: 14px;
        margin: 0;
    }

    .btn-back {
        background: #5d4037;
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(93, 64, 55, 0.3);
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .btn-back:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(93, 64, 55, 0.4);
        background: #4e342e;
        color: white;
        text-decoration: none;
    }

    .content-card {
        background: #FFFDF7;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(210, 180, 140, 0.2);
        max-width: 900px;
        margin: 0 auto;
    }

    .alert {
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
        border: none;
        font-size: 14px;
        font-family: 'Nunito', 'Poppins', sans-serif;
    }

    .alert-success {
        background: #D4EDDA;
        color: #155724;
    }

    .alert-error,
    .alert-danger {
        background: #F8D7DA;
        color: #721C24;
    }

    .form-section {
        margin-top: 20px;
    }

    @media (max-width: 768px) {
        .page-container {
            padding: 20px 15px;
        }

        .content-card {
            padding: 24px 16px;
        }

        .page-title {
            font-size: 28px;
        }

        .page-header {
            flex-direction: column;
        }

        .btn-back {
            width: 100%;
            justify-content: center;
        }
    }
</style>
{% endblock %}

