{% extends 'base_public.html.twig' %}

{% block title %}Contact Us - CasaClick{% endblock %}

{% block body %}
<section class="contact-hero">
    <h1>Contact Us</h1>
    <p>Have questions? We'd love to hear from you.</p>
</section>

<section class="contact-content">
    <div class="contact-intro">
        <p>Fill out the form below. After submission, you'll see a confirmation message.</p>
    </div>
    {# Google Forms embed - Create your form at forms.google.com, then replace the URL below #}
    <div class="contact-form-wrapper">
        <iframe
            src="https://docs.google.com/forms/d/e/1FAIpQLSfQXm8Y3Z6QvJ2XK8rN4pL9mB1cD7eF3aH5gI6jK0lM2nO4qR8sT/viewform?embedded=true"
            width="100%"
            height="600"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            title="Contact Form"
        >Loading…</iframe>
    </div>
    <p class="form-note"><i class="fa fa-info-circle"></i> To use your own form: create one at <a href="https://forms.google.com" target="_blank" rel="noopener">forms.google.com</a>, click Share → Embed, and paste the iframe src in the contact template.</p>
</section>

<style>
.contact-hero {
    background: linear-gradient(135deg, #5c4033, #8B4513);
    color: white;
    padding: 60px 24px;
    text-align: center;
}
.contact-hero h1 { font-size: clamp(2rem, 4vw, 2.5rem); margin: 0 0 8px; }
.contact-hero p { margin: 0; opacity: 0.95; }
.contact-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 48px 24px;
}
.contact-intro { margin-bottom: 24px; text-align: center; }
.contact-intro a { color: #8B4513; font-weight: 600; }
.contact-form-wrapper {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.contact-form-wrapper iframe { display: block; min-height: 500px; }
.form-note { margin-top: 16px; font-size: 0.9rem; color: #666; }
</style>
{% endblock %}
