{% extends 'base_public.html.twig' %}

{% block title %}Contact Us - CasaClick{% endblock %}

{% block body %}
<div class="contact-propeble">
  <header class="contact-propeble__hero">
    <p class="contact-propeble__eyebrow">Contact</p>
    <h1 class="contact-propeble__title">Let’s work together—we can do more</h1>
    <p class="contact-propeble__lead">Have questions about listings, your account, or partnering with CasaClick? Reach out—we’d love to hear from you.</p>
  </header>

  <section class="contact-propeble__info" aria-label="Contact details">
    <div class="contact-propeble__info-grid">
      <article class="contact-propeble__card">
        <div class="contact-propeble__card-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        </div>
        <h2 class="contact-propeble__card-title">Our office</h2>
        <p class="contact-propeble__card-text">CasaClick HQ<br>Daro, Dumaguete City, Philippines</p>
      </article>
      <article class="contact-propeble__card">
        <div class="contact-propeble__card-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.608-1.288.684-1.189.204-2.381-.335-3.197-1.27l-.001-.001-1.79-2.25m0 0c-.396-.495-.5-1.146-.315-1.733l1.21-1.894a1.125 1.125 0 011.092-.468l1.978.263c.47.062.9.33 1.15.77l.97 1.293c.282.376.769.608 1.288.684 1.189.204 2.381-.335 3.197-1.27l-.001-.001-1.79-2.25"/></svg>
        </div>
        <h2 class="contact-propeble__card-title">Contact us</h2>
        <p class="contact-propeble__card-text">
          <a href="tel:+639294551270">+63 929 455 1270</a><br>
          <a href="mailto:binrazalimohammadfirdaus@gmail.com">binrazalimohammadfirdaus@gmail.com</a>
        </p>
      </article>
      <article class="contact-propeble__card">
        <div class="contact-propeble__card-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.935-2.186 2.25 2.25 0 00-3.935 2.186z"/></svg>
        </div>
        <h2 class="contact-propeble__card-title">Social media</h2>
        <p class="contact-propeble__card-text contact-propeble__social">
          <a href="#" rel="noopener noreferrer" aria-label="Instagram">Instagram</a>
          <span class="contact-propeble__social-sep">·</span>
          <a href="#" rel="noopener noreferrer" aria-label="Facebook">Facebook</a>
        </p>
      </article>
    </div>
  </section>

  <section class="contact-propeble__form-block" aria-labelledby="form-heading">
    <div class="contact-propeble__form-inner">
      <p class="contact-propeble__form-eyebrow">Comments &amp; feedback</p>
      <h2 id="form-heading" class="contact-propeble__form-title">Fill in the form to share comments and feedback</h2>
      <p class="contact-propeble__form-intro">This form is for your comments and feedback about CasaClick. Submit your message below—after submission, you’ll see a confirmation from the form provider.</p>
      <div class="contact-propeble__iframe-wrap">
        <iframe
          src="https://docs.google.com/forms/d/e/1FAIpQLScd7HLMjTjCgQ9MsjV2VXpBv8HkZCrnqK8VHrVp6Ec2BpRCLw/viewform?embedded=true"
          width="100%"
          height="720"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="CasaClick contact form (Google Forms)"
          loading="lazy"
        >Loading…</iframe>
      </div>
      <p class="contact-propeble__form-note">
        <i class="fa fa-info-circle" aria-hidden="true"></i>
        Prefer a new tab?
        <a href="https://docs.google.com/forms/d/e/1FAIpQLScd7HLMjTjCgQ9MsjV2VXpBv8HkZCrnqK8VHrVp6Ec2BpRCLw/viewform" target="_blank" rel="noopener noreferrer">Open the form on Google</a>.
      </p>
    </div>
  </section>
</div>

<style>
/* CasaClick palette (matches About / landing) */
.contact-propeble {
  overflow-x: clip;
  max-width: 100%;
  --cp-brown: #5c4033;
  --cp-gold: #8B4513;
  --cp-sienna: #A0522D;
  --cp-tan: #D2B48C;
  --cp-cream: #FFFDF7;
  --cp-soft: #f9f7f4;
  --cp-white: #ffffff;
  --cp-text: #3e2723;
  --cp-muted: #6d4c41;
  --cp-line: rgba(92, 64, 51, 0.12);
  font-family: 'Nunito', 'Poppins', system-ui, sans-serif;
  color: var(--cp-text);
  background: var(--cp-cream);
}

.contact-propeble__hero {
  text-align: center;
  padding: 3rem 1.5rem 2.5rem;
  max-width: 720px;
  margin: 0 auto;
}
.contact-propeble__eyebrow {
  font-size: 0.75rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--cp-gold);
  font-weight: 700;
  margin: 0 0 0.75rem;
}
.contact-propeble__title {
  font-size: clamp(1.75rem, 3.5vw, 2.35rem);
  font-weight: 800;
  color: var(--cp-brown);
  margin: 0 0 1rem;
  line-height: 1.2;
}
.contact-propeble__lead {
  margin: 0;
  font-size: 1.05rem;
  color: var(--cp-muted);
  line-height: 1.65;
}

.contact-propeble__info {
  padding: 0 1.5rem 2.5rem;
  max-width: 1100px;
  margin: 0 auto;
}
.contact-propeble__info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.contact-propeble__card {
  background: var(--cp-white);
  border: 1px solid var(--cp-line);
  border-radius: 12px;
  padding: 2rem 1.5rem;
  text-align: center;
  box-shadow: 0 8px 28px rgba(92, 64, 51, 0.07);
  transition: box-shadow 0.25s, border-color 0.25s, transform 0.2s;
}
.contact-propeble__card:hover {
  border-color: rgba(139, 69, 19, 0.2);
  box-shadow: 0 14px 40px rgba(92, 64, 51, 0.1);
  transform: translateY(-2px);
}
.contact-propeble__card-icon {
  color: var(--cp-gold);
  margin-bottom: 1rem;
  display: flex;
  justify-content: center;
}
.contact-propeble__card-title {
  font-size: 0.7rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--cp-gold);
  font-weight: 800;
  margin: 0 0 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 2px solid var(--cp-tan);
}
.contact-propeble__card-text {
  margin: 0;
  font-size: 0.95rem;
  color: var(--cp-muted);
  line-height: 1.65;
}
.contact-propeble__card-text a {
  color: var(--cp-gold);
  font-weight: 600;
  text-decoration: none;
}
.contact-propeble__card-text a:hover {
  text-decoration: underline;
}
.contact-propeble__social {
  font-weight: 600;
}
.contact-propeble__social-sep {
  margin: 0 0.35rem;
  opacity: 0.5;
}

.contact-propeble__form-block {
  background: var(--cp-soft);
  border-top: 1px solid var(--cp-line);
  padding: 3.5rem 1.5rem 4.5rem;
}
.contact-propeble__form-inner {
  max-width: min(720px, 100%);
  margin: 0 auto;
  padding: 0 clamp(0px, 2vw, 8px);
  box-sizing: border-box;
}
.contact-propeble__form-eyebrow {
  font-size: 0.75rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--cp-gold);
  font-weight: 700;
  margin: 0 0 0.5rem;
  text-align: center;
}
.contact-propeble__form-title {
  font-size: clamp(1.5rem, 3vw, 1.85rem);
  color: var(--cp-brown);
  margin: 0 0 0.75rem;
  text-align: center;
  font-weight: 800;
}
.contact-propeble__form-intro {
  margin: 0 0 2rem;
  text-align: center;
  color: var(--cp-muted);
  line-height: 1.65;
  font-size: 0.98rem;
}
.contact-propeble__iframe-wrap {
  background: var(--cp-white);
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--cp-line);
  box-shadow: 0 10px 36px rgba(92, 64, 51, 0.08);
  max-width: 100%;
  -webkit-overflow-scrolling: touch;
}
.contact-propeble__iframe-wrap iframe {
  display: block;
  width: 100% !important;
  max-width: 100%;
  height: min(72vh, 720px);
  min-height: min(420px, 55vh);
  border: 0;
}

.contact-propeble__form-note {
  margin-top: 1.25rem;
  font-size: 0.88rem;
  color: var(--cp-muted);
  line-height: 1.55;
}
.contact-propeble__form-note a {
  color: var(--cp-gold);
  font-weight: 600;
}
.contact-propeble__form-note code {
  font-size: 0.82rem;
  background: rgba(139, 69, 19, 0.08);
  padding: 0.1rem 0.35rem;
  border-radius: 4px;
  color: var(--cp-brown);
}

@media (max-width: 900px) {
  .contact-propeble__info-grid {
    grid-template-columns: 1fr;
    max-width: 420px;
    margin: 0 auto;
  }
}
</style>
{% endblock %}
