<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>body{font-family:sans-serif;line-height:1.6;color:#333;}.btn{display:inline-block;padding:12px 24px;background:#8B4513;color:white;text-decoration:none;border-radius:8px;}</style>
</head>
<body>
    <h1>Verify your CasaClick account</h1>
    <p>Hi {{ user.name }},</p>
    <p>Please verify your email by clicking the button below:</p>
    <p><a href="{{ verifyUrl }}" class="btn">Verify Email</a></p>
    <p>Or copy this link: {{ verifyUrl }}</p>
    <p>This link expires in 24 hours.</p>
    <p>If you didn't create an account, you can ignore this email.</p>
</body>
</html>
