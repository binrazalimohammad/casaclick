<form method="post"
      action="{{ path('app_landlord_delete', {'id': landlord.id}) }}"
      onsubmit="return confirm('Are you sure you want to delete this landlord?');"
      style="display:inline-block;">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ landlord.id) }}">

    <button class="btn"
        style="
            background:#A0522D;
            color:#fff;
            border:none;
            border-radius:8px;
            padding:8px 16px;
            font-weight:bold;
            box-shadow:0 3px 6px rgba(0,0,0,0.2);
            transition:all 0.3s ease;
        "
        onmouseover="this.style.background='#8B4513'"
        onmouseout="this.style.background='#A0522D'">
        🗑 Delete
    </button>
</form>
