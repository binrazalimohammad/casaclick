{% extends 'base.html.twig' %}

{% block title %}Landlord Profiles{% endblock %}

{% block body %}
<div class="listings-container">
    <div class="page-title">
        <i class="fa fa-user-tie" style="font-size: 1.2em; color: #8B4513; margin-right: 12px;"></i> Landlord Profiles
    </div>
    
    <div class="header-actions">
        <a href="{{ path('app_dashboard') }}" class="btn btn-outline-dark">
            <i class="fa fa-arrow-left"></i> Dashboard
        </a>
        <a href="{{ path('app_landlord_new') }}" class="btn btn-dark">
            <i class="fa fa-plus"></i> New Landlord
        </a>
    </div>

    <!-- Landlord Profiles Tiles -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card p-4" style="border-radius: 16px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0"><i class="fa fa-user-tie" style="color: #8B4513; margin-right: 8px;"></i> Landlord Profiles</h3>
                    <span class="badge bg-warning">{{ landlords|length }} Registered</span>
                </div>
                <div class="profile-tiles">
                    {% for landlord in landlords %}
                        <div class="profile-tile landlord-tile">
                            <div class="profile-avatar landlord-avatar">
                                <i class="ti-briefcase"></i>
                            </div>
                            <div class="profile-content">
                                <h5 class="profile-name">{{ landlord.FirstName }} {{ landlord.LastName }}</h5>
                                <p class="profile-email">{{ landlord.Email }}</p>
                                <p class="profile-phone">{{ landlord.Phone }}</p>
                                {% if landlord.Address %}
                                    <p class="profile-address">{{ landlord.Address|slice(0, 50) }}{% if landlord.Address|length > 50 %}...{% endif %}</p>
                                {% endif %}
                                <div class="profile-actions">
                                    <a href="{{ path('app_landlord_show', {'id': landlord.id}) }}" class="btn btn-sm btn-outline-warning">
                                        <i class="ti-eye"></i> View Profile
                                    </a>
                                    <a href="{{ path('app_landlord_edit', {'id': landlord.id}) }}" class="btn btn-sm btn-warning">
                                        <i class="ti-pencil"></i> Edit
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-5">
                            <i class="ti-briefcase" style="font-size: 48px; color: #ddd;"></i>
                            <p class="mt-2">No landlord profiles found</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
