{% extends 'base.html.twig' %}

{% block title %}{{ landlord.FirstName }} {{ landlord.LastName }} - Landlord Profile{% endblock %}

{% block body %}
<div class="page-container">
    <div class="page-header">
        <div class="breadcrumb">
            <a href="{{ path('app_landlord_index') }}" class="breadcrumb-link">
                <i class="ti-list"></i> Landlords
            </a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">{{ landlord.FirstName }} {{ landlord.LastName }}</span>
        </div>
    </div>

    <div class="profile-container">
        <!-- Profile Header -->
        <div class="profile-header">
            <div class="profile-avatar">
                <div class="avatar-circle">
                    <i class="ti-user"></i>
                </div>
                <div class="avatar-status online"></div>
            </div>
            
            <div class="profile-info">
                <h1 class="profile-name">{{ landlord.FirstName }} {{ landlord.LastName }}</h1>
                <p class="profile-title">Property Landlord</p>
                <div class="profile-badges">
                    <span class="badge badge-primary">Active</span>
                    <span class="badge badge-secondary">ID: {{ landlord.id }}</span>
                </div>
            </div>
            
            <div class="profile-actions">
                <a href="{{ path('app_landlord_edit', {'id': landlord.id}) }}" class="action-btn edit-btn">
                    <i class="ti-pencil"></i>
                    <span>Edit</span>
                </a>
                {{ include('landlord/_delete_form.html.twig') }}
            </div>
        </div>

        <!-- Profile Content -->
        <div class="profile-content">
            <!-- Contact Information -->
            <div class="info-section">
                <div class="section-header">
                    <i class="ti-email"></i>
                    <h3>Contact Information</h3>
                </div>
                
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="ti-email"></i>
                        </div>
                        <div class="info-content">
                            <label>Email Address</label>
                            <a href="mailto:{{ landlord.Email }}" class="info-value email-link">
                                {{ landlord.Email }}
                            </a>
                        </div>
                    </div>
                    
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="ti-mobile"></i>
                        </div>
                        <div class="info-content">
                            <label>Phone Number</label>
                            <a href="tel:{{ landlord.Phone }}" class="info-value phone-link">
                                {{ landlord.Phone }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Address Information -->
            {% if landlord.Address %}
            <div class="info-section">
                <div class="section-header">
                    <i class="ti-location-pin"></i>
                    <h3>Address Information</h3>
                </div>
                
                <div class="info-item full-width">
                    <div class="info-icon">
                        <i class="ti-location-pin"></i>
                    </div>
                    <div class="info-content">
                        <label>Full Address</label>
                        <div class="info-value address-text">
                            {{ landlord.Address }}
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}

            <!-- Quick Actions -->
            <div class="info-section">
                <div class="section-header">
                    <i class="ti-settings"></i>
                    <h3>Quick Actions</h3>
                </div>
                
                <div class="quick-actions">
                    <a href="mailto:{{ landlord.Email }}" class="quick-action-btn">
                        <i class="ti-email"></i>
                        <span>Send Email</span>
                    </a>
                    
                    <a href="tel:{{ landlord.Phone }}" class="quick-action-btn">
                        <i class="ti-mobile"></i>
                        <span>Call Now</span>
                    </a>
                    
                    <a href="{{ path('app_landlord_edit', {'id': landlord.id}) }}" class="quick-action-btn">
                        <i class="ti-pencil"></i>
                        <span>Edit Profile</span>
                    </a>
                    
                    <button class="quick-action-btn copy-btn" onclick="copyToClipboard('{{ landlord.Email }}')">
                        <i class="ti-files"></i>
                        <span>Copy Email</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="profile-navigation">
            <a href="{{ path('app_landlord_index') }}" class="nav-btn back-btn">
                <i class="ti-arrow-left"></i>
                <span>Back to Landlords</span>
            </a>
            
            <div class="nav-actions">
                <a href="{{ path('app_landlord_edit', {'id': landlord.id}) }}" class="nav-btn edit-btn">
                    <i class="ti-pencil"></i>
                    <span>Edit Profile</span>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div class="toast-notification" id="toast">
    <div class="toast-content">
        <i class="ti-check"></i>
        <span>Email copied to clipboard!</span>
    </div>
</div>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(function() {
        showToast();
    }).catch(function(err) {
        console.error('Could not copy text: ', err);
    });
}

function showToast() {
    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(() => {
        toast.classList.remove('show');
    }, 3000);
}

// Add smooth animations on page load
document.addEventListener('DOMContentLoaded', function() {
    const sections = document.querySelectorAll('.info-section');
    sections.forEach((section, index) => {
        section.style.animationDelay = `${index * 0.1}s`;
        section.classList.add('animate-in');
    });
});
</script>

<style>
    /* ========================================
       LANDLORD PROFILE STYLES
       ======================================== */
    
    .page-container {
        background: linear-gradient(135deg, #F8F5EE 0%, #F0E6D2 100%);
        min-height: 100vh;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }

    .page-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            radial-gradient(circle at 20% 80%, rgba(139, 69, 19, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(210, 180, 140, 0.1) 0%, transparent 50%);
        pointer-events: none;
    }

    .page-header {
        width: 100%;
        max-width: 900px;
        margin-bottom: 30px;
        position: relative;
        z-index: 1;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: #8B7355;
        margin-bottom: 20px;
    }

    .breadcrumb-link {
        color: #8B4513;
        text-decoration: none;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
        padding: 6px 12px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(10px);
    }

    .breadcrumb-link:hover {
        color: #5C4033;
        background: rgba(255, 255, 255, 0.8);
        transform: translateY(-1px);
        text-decoration: none;
    }

    .breadcrumb-separator {
        color: #D2B48C;
        font-weight: 300;
    }

    .breadcrumb-current {
        color: #5C4033;
        font-weight: 600;
        padding: 6px 12px;
        background: rgba(139, 69, 19, 0.1);
        border-radius: 8px;
    }

    .profile-container {
        width: 100%;
        max-width: 900px;
        background: linear-gradient(135deg, #FFFDF7 0%, #F8F5EE 100%);
        border-radius: 24px;
        box-shadow: 
            0 20px 60px rgba(0, 0, 0, 0.1),
            0 8px 32px rgba(139, 69, 19, 0.1);
        border: 1px solid rgba(210, 180, 140, 0.3);
        position: relative;
        overflow: hidden;
        z-index: 1;
    }

    .profile-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #8B4513, #D2B48C, #8B4513);
        background-size: 200% 100%;
        animation: shimmer 3s ease-in-out infinite;
    }

    @keyframes shimmer {
        0%, 100% { background-position: 200% 0; }
        50% { background-position: -200% 0; }
    }

    /* Profile Header */
    .profile-header {
        display: flex;
        align-items: center;
        padding: 40px;
        gap: 30px;
        border-bottom: 2px solid rgba(210, 180, 140, 0.2);
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(10px);
    }

    .profile-avatar {
        position: relative;
        flex-shrink: 0;
    }

    .avatar-circle {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #8B4513, #A0522D);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 12px 32px rgba(139, 69, 19, 0.3);
        position: relative;
    }

    .avatar-circle::before {
        content: '';
        position: absolute;
        inset: -3px;
        background: linear-gradient(135deg, #8B4513, #A0522D, #8B4513);
        border-radius: 50%;
        z-index: -1;
        opacity: 0.3;
        filter: blur(8px);
    }

    .avatar-circle i {
        font-size: 48px;
        color: white;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    }

    .avatar-status {
        position: absolute;
        bottom: 8px;
        right: 8px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        border: 3px solid white;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .avatar-status.online {
        background: #27ae60;
    }

    .profile-info {
        flex: 1;
    }

    .profile-name {
        color: #5C4033;
        font-size: 32px;
        font-weight: 800;
        margin: 0 0 8px 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        letter-spacing: -0.5px;
    }

    .profile-title {
        color: #8B7355;
        font-size: 18px;
        font-weight: 500;
        margin: 0 0 16px 0;
        opacity: 0.8;
    }

    .profile-badges {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .badge {
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-primary {
        background: linear-gradient(135deg, #27ae60, #2ecc71);
        color: white;
        box-shadow: 0 4px 12px rgba(39, 174, 96, 0.3);
    }

    .badge-secondary {
        background: rgba(139, 69, 19, 0.1);
        color: #8B4513;
        border: 1px solid rgba(139, 69, 19, 0.2);
    }

    .profile-actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex-shrink: 0;
    }

    .action-btn {
        background: linear-gradient(135deg, #8B4513, #A0522D);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 20px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'Nunito', 'Poppins', 'Quicksand', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 6px 20px rgba(139, 69, 19, 0.3);
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        position: relative;
        overflow: hidden;
    }

    .action-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.6s ease;
    }

    .action-btn:hover {
        background: linear-gradient(135deg, #A0522D, #8B4513);
        color: white;
        text-decoration: none;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(139, 69, 19, 0.4);
    }

    .action-btn:hover::before {
        left: 100%;
    }

    /* Profile Content */
    .profile-content {
        padding: 40px;
    }

    .info-section {
        background: rgba(255, 255, 255, 0.6);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
        border: 1px solid rgba(210, 180, 140, 0.2);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        opacity: 0;
        transform: translateY(20px);
    }

    .info-section.animate-in {
        opacity: 1;
        transform: translateY(0);
        animation: slideInUp 0.6s ease-out forwards;
    }

    @keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .info-section:hover {
        background: rgba(255, 255, 255, 0.8);
        border-color: rgba(210, 180, 140, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid rgba(210, 180, 140, 0.2);
    }

    .section-header i {
        color: #8B4513;
        font-size: 20px;
    }

    .section-header h3 {
        color: #5C4033;
        font-size: 18px;
        font-weight: 700;
        margin: 0;
        font-family: 'Nunito', 'Poppins', 'Quicksand', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .info-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 16px;
        background: rgba(255, 255, 255, 0.8);
        border-radius: 12px;
        border: 1px solid rgba(210, 180, 140, 0.2);
        transition: all 0.3s ease;
    }

    .info-item:hover {
        background: rgba(255, 255, 255, 1);
        border-color: rgba(139, 69, 19, 0.3);
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    }

    .info-item.full-width {
        grid-column: 1 / -1;
    }

    .info-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #8B4513, #A0522D);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(139, 69, 19, 0.3);
    }

    .info-icon i {
        color: white;
        font-size: 18px;
    }

    .info-content {
        flex: 1;
    }

    .info-content label {
        color: #8B7355;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
        display: block;
    }

    .info-value {
        color: #5C4033;
        font-size: 16px;
        font-weight: 500;
        text-decoration: none;
        display: block;
        word-break: break-word;
    }

    .email-link:hover,
    .phone-link:hover {
        color: #8B4513;
        text-decoration: underline;
    }

    .address-text {
        line-height: 1.6;
        white-space: pre-line;
    }

    /* Quick Actions */
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
    }

    .quick-action-btn {
        background: rgba(255, 255, 255, 0.8);
        color: #5C4033;
        border: 2px solid rgba(210, 180, 140, 0.3);
        border-radius: 12px;
        padding: 16px 20px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'Nunito', 'Poppins', 'Quicksand', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        backdrop-filter: blur(10px);
    }

    .quick-action-btn:hover {
        background: rgba(255, 255, 255, 1);
        border-color: #8B4513;
        color: #8B4513;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
        text-decoration: none;
    }

    .quick-action-btn i {
        font-size: 18px;
        color: #8B4513;
    }

    /* Profile Navigation */
    .profile-navigation {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 30px 40px;
        border-top: 2px solid rgba(210, 180, 140, 0.2);
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(10px);
    }

    .nav-btn {
        background: linear-gradient(135deg, #8B4513, #A0522D);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 16px 24px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'Nunito', 'Poppins', 'Quicksand', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 6px 20px rgba(139, 69, 19, 0.3);
        display: flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        position: relative;
        overflow: hidden;
    }

    .nav-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.6s ease;
    }

    .nav-btn:hover {
        background: linear-gradient(135deg, #A0522D, #8B4513);
        color: white;
        text-decoration: none;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(139, 69, 19, 0.4);
    }

    .nav-btn:hover::before {
        left: 100%;
    }

    .nav-actions {
        display: flex;
        gap: 12px;
    }

    /* Toast Notification */
    .toast-notification {
        position: fixed;
        top: 20px;
        right: 20px;
        background: linear-gradient(135deg, #27ae60, #2ecc71);
        color: white;
        padding: 16px 24px;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(39, 174, 96, 0.3);
        transform: translateX(400px);
        transition: transform 0.3s ease;
        z-index: 1000;
    }

    .toast-notification.show {
        transform: translateX(0);
    }

    .toast-content {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
    }

    .toast-content i {
        font-size: 18px;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .page-container {
            padding: 20px 15px;
        }
        
        .profile-header {
            flex-direction: column;
            text-align: center;
            gap: 20px;
            padding: 30px 20px;
        }
        
        .profile-actions {
            flex-direction: row;
            justify-content: center;
        }
        
        .profile-content {
            padding: 20px;
        }
        
        .info-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
        
        .quick-actions {
            grid-template-columns: 1fr;
        }
        
        .profile-navigation {
            flex-direction: column;
            gap: 16px;
            padding: 20px;
        }
        
        .nav-actions {
            width: 100%;
            justify-content: center;
        }
        
        .profile-name {
            font-size: 24px;
        }
        
        .avatar-circle {
            width: 80px;
            height: 80px;
        }
        
        .avatar-circle i {
            font-size: 32px;
        }
    }

    @media (max-width: 480px) {
        .page-container {
            padding: 16px 12px;
        }
        
        .profile-header {
            padding: 20px 16px;
        }
        
        .profile-content {
            padding: 16px;
        }
        
        .info-section {
            padding: 16px;
        }
        
        .profile-navigation {
            padding: 16px;
        }
        
        .breadcrumb {
            flex-wrap: wrap;
            gap: 4px;
        }
    }

    /* Accessibility */
    .nav-btn:focus-visible,
    .action-btn:focus-visible,
    .quick-action-btn:focus-visible {
        outline: 2px solid #8B4513;
        outline-offset: 2px;
    }

    /* High Contrast Mode */
    @media (prefers-contrast: high) {
        .info-item {
            border-width: 2px;
        }
        
        .nav-btn,
        .action-btn {
            border: 2px solid #000;
        }
    }

    /* Reduced Motion */
    @media (prefers-reduced-motion: reduce) {
        * {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
        
        .profile-container::before {
            animation: none;
        }
    }
</style>
{% endblock %}
